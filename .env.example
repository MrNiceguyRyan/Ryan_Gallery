# Mapbox public access token
# Get yours at https://account.mapbox.com/access-tokens/
PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiXXXXXXXXX

# Sanity write token for local maintenance scripts only.
# Never commit a real token; pass it via your shell or local .env.
# SANITY_TOKEN=sk...

# Personal info hub URL — when set, the footer shows a "← personal hub" link
# and Layout.astro injects <link rel="me" href="..."> for IndieAuth / identity
# linking. Leave blank to hide.
# PUBLIC_HUB_URL=https://your-hub.example.com
