# Mapbox public access token
# Get yours at https://account.mapbox.com/access-tokens/
PUBLIC_MAPBOX_TOKEN=pk.eyJ1IjoiXXXXXXXXX

# Sanity write token for local photo uploads.
# Required by scripts/upload-photos.mjs; never commit a real token.
SANITY_TOKEN=skxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Personal info hub URL — when set, the footer shows a "← personal hub" link
# and Layout.astro injects <link rel="me" href="..."> for IndieAuth / identity
# linking. Leave blank to hide.
# PUBLIC_HUB_URL=https://your-hub.example.com

# Optional Claude API key used by scripts/upload-photos.mjs for AI-generated
# photo titles. Omit to use deterministic city/index titles.
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
