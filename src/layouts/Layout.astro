---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const {
  title = 'Ryan | Visual Archive',
  description = 'A curated collection of photographic moments — shot on Nikon Zf, engineered with intention.',
  ogImage = 'https://cdn.sanity.io/images/z610fooo/production/e69f9258142218c5cd649a9c01d4fe89d0335563-6048x4032.jpg?auto=format&w=1200&q=85',
  ogType = 'website',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://ryangallery.com');
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.20.0/mapbox-gl.css" rel="stylesheet" />

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#0A0A0A" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Ryan Xu | Visual Archive" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Astro View Transitions — smooth page navigation -->
    <ClientRouter />
  </head>

  <body class="bg-white min-h-screen text-gray-900 font-sans antialiased overflow-x-hidden" style="cursor: none;">
    <!-- Custom cursor -->
    <div id="cursor-dot" aria-hidden="true"></div>
    <div id="cursor-ring" aria-hidden="true">
      <!-- Aperture SVG shown on filmstrip hover -->
      <svg id="cursor-aperture" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg"
           style="position:absolute;inset:0;width:100%;height:100%;opacity:0;transition:opacity 0.4s ease">
        <circle cx="20" cy="20" r="18" stroke="white" stroke-width="0.8" fill="none"/>
        <path id="ap-blade-0" d="" fill="white"/>
        <path id="ap-blade-1" d="" fill="white"/>
        <path id="ap-blade-2" d="" fill="white"/>
        <path id="ap-blade-3" d="" fill="white"/>
        <path id="ap-blade-4" d="" fill="white"/>
        <path id="ap-blade-5" d="" fill="white"/>
      </svg>
      <!-- Location label -->
      <span id="cursor-label" style="
        position:absolute;
        bottom:-22px;
        left:50%;
        transform:translateX(-50%);
        white-space:nowrap;
        font-size:9px;
        letter-spacing:0.2em;
        text-transform:uppercase;
        color:rgba(255,255,255,0.8);
        font-family:ui-monospace,monospace;
        opacity:0;
        transition:opacity 0.4s ease;
        pointer-events:none;
      "></span>
    </div>
    <slot />

    <!-- Global image protection: prevent right-click, drag & long-press save -->
    <style is:global>
      img {
        -webkit-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
        pointer-events: auto;
        -webkit-user-drag: none;
      }

      /* ─── View Transition animations ─── */

      /* Default page: fade + subtle lift */
      ::view-transition-old(root) {
        animation: vt-fade-out 0.35s cubic-bezier(0.4, 0, 1, 1) both;
      }
      ::view-transition-new(root) {
        animation: vt-fade-in 0.45s cubic-bezier(0, 0, 0.2, 1) both;
      }

      @keyframes vt-fade-out {
        from { opacity: 1; transform: translateY(0) scale(1); }
        to   { opacity: 0; transform: translateY(-8px) scale(0.99); }
      }
      @keyframes vt-fade-in {
        from { opacity: 0; transform: translateY(12px) scale(0.99); }
        to   { opacity: 1; transform: translateY(0) scale(1); }
      }

      /* Nav bar: fast crossfade so color change feels intentional, not jarring */
      ::view-transition-old(nav) {
        animation: vt-fade-out 0.2s ease both;
      }
      ::view-transition-new(nav) {
        animation: vt-fade-in 0.25s ease both;
      }

      /* Page title heading — slides in from below */
      ::view-transition-old(page-title) {
        animation: vt-title-out 0.3s cubic-bezier(0.4, 0, 1, 1) both;
      }
      ::view-transition-new(page-title) {
        animation: vt-title-in 0.5s cubic-bezier(0.16, 1, 0.3, 1) 0.05s both;
      }

      @keyframes vt-title-out {
        from { opacity: 1; transform: translateY(0); }
        to   { opacity: 0; transform: translateY(-20px); }
      }
      @keyframes vt-title-in {
        from { opacity: 0; transform: translateY(24px); }
        to   { opacity: 1; transform: translateY(0); }
      }

      /* Hero image — scale crossfade */
      ::view-transition-old(hero-image) {
        animation: vt-hero-out 0.4s cubic-bezier(0.4, 0, 1, 1) both;
      }
      ::view-transition-new(hero-image) {
        animation: vt-hero-in 0.55s cubic-bezier(0.16, 1, 0.3, 1) both;
      }

      @keyframes vt-hero-out {
        from { opacity: 1; transform: scale(1); }
        to   { opacity: 0; transform: scale(1.04); }
      }
      @keyframes vt-hero-in {
        from { opacity: 0; transform: scale(1.04); }
        to   { opacity: 1; transform: scale(1); }
      }


      /* ─── Shared element: cover image flies into WorkDetailPage ─── */
      /* The browser handles the morph automatically via the matching
         viewTransitionName; we only tune the easing and duration here.  */
      ::view-transition-old(cover-*),
      ::view-transition-new(cover-*) {
        animation-duration: 0.55s;
        animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
        /* Preserve the image's aspect during the morph */
        object-fit: cover;
        overflow: clip;
      }
      ::view-transition-new(cover-*) {
        animation-name: none;          /* browser handles the geometry */
      }
      ::view-transition-old(cover-*) {
        animation-name: none;
      }

      /* Reduce motion: instant transition for accessibility */
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root),
        ::view-transition-old(page-title),
        ::view-transition-new(page-title),
        ::view-transition-old(hero-image),
        ::view-transition-new(hero-image) {
          animation: none;
        }
      }
    </style>

    <style is:inline>
      /* Hide default cursor everywhere except lightbox */
      *, *::before, *::after { cursor: none !important; }
      /* Lightbox: restore default cursor (custom cursor is hidden via cursor-hidden class) */
      .cursor-hidden ~ * { cursor: default; }
      [style*="cursor: default"], [style*="cursor: default"] * { cursor: default !important; }

      #cursor-dot {
        position: fixed;
        top: 0; left: 0;
        width: 5px; height: 5px;
        margin: -2.5px 0 0 -2.5px;
        background: white;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        will-change: left, top;
        mix-blend-mode: difference;
      }

      #cursor-ring {
        position: fixed;
        top: 0; left: 0;
        width: 32px; height: 32px;
        margin: -16px 0 0 -16px;
        border: 1px solid white;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9998;
        will-change: left, top;
        mix-blend-mode: difference;
        opacity: 0.45;
        transform-origin: center center;
        transition: transform 0.5s cubic-bezier(0.16,1,0.3,1),
                    border-width 0.4s cubic-bezier(0.16,1,0.3,1),
                    opacity 0.4s ease;
      }

      body.cursor-hover #cursor-ring {
        transform: scale(1.5);
        border-width: 0.5px;
        opacity: 0.28;
      }
      body.cursor-click #cursor-ring {
        transform: scale(0.72);
        border-width: 1.5px;
        opacity: 0.9;
        transition: transform 0.1s ease, opacity 0.1s ease;
      }
      /* Filmstrip: large aperture cursor */
      body.cursor-filmstrip #cursor-ring {
        width: 72px;
        height: 72px;
        margin: -36px 0 0 -36px;
        border-width: 0;
        opacity: 1;
        transform: scale(1);
        transition: width 0.5s cubic-bezier(0.16,1,0.3,1),
                    height 0.5s cubic-bezier(0.16,1,0.3,1),
                    margin 0.5s cubic-bezier(0.16,1,0.3,1),
                    opacity 0.4s ease;
      }
      body.cursor-filmstrip #cursor-dot {
        opacity: 0;
      }
      body.cursor-hidden #cursor-dot,
      body.cursor-hidden #cursor-ring { opacity: 0 !important; }

      @media (hover: none) {
        #cursor-dot, #cursor-ring { display: none !important; }
        *, *::before, *::after { cursor: auto !important; }
      }
    </style>

    <script is:inline>
      // ── Custom cursor ──
      (function() {
        var mouseX = -100, mouseY = -100;
        var ringX  = -100, ringY  = -100;
        var raf = null;
        var initialized = false;

        function lerp(a, b, t) { return a + (b - a) * t; }

        function init() {
          var dot  = document.getElementById('cursor-dot');
          var ring = document.getElementById('cursor-ring');
          if (!dot || !ring) return;

          // Clean up previous raf loop before starting new one
          if (raf) { cancelAnimationFrame(raf); raf = null; }

          // Reset classes on body
          document.body.classList.remove('cursor-hover', 'cursor-click', 'cursor-hidden');

          function loop() {
            ringX = lerp(ringX, mouseX, 0.12);
            ringY = lerp(ringY, mouseY, 0.12);
            // Use left/top so CSS transform:scale() has a stable origin at element center
            ring.style.left = ringX + 'px';
            ring.style.top  = ringY + 'px';
            raf = requestAnimationFrame(loop);
          }
          loop();

          if (initialized) return; // only attach document listeners once
          initialized = true;

          var hoverEls = 'a, button, [role="button"], .filmstrip-item, .cursor-pointer, input, textarea, select, label';

          document.addEventListener('mousemove', function(e) {
            mouseX = e.clientX;
            mouseY = e.clientY;

            // Dot: snap directly via left/top — no transform conflict
            var d = document.getElementById('cursor-dot');
            if (d) { d.style.left = mouseX + 'px'; d.style.top = mouseY + 'px'; }

              // Hover state
            var isHover = !!(e.target && e.target.closest && e.target.closest(hoverEls));
            var isFilmstrip = !!(e.target && e.target.closest && e.target.closest('.filmstrip-item'));

            if (isFilmstrip) {
              document.body.classList.add('cursor-filmstrip');
              document.body.classList.remove('cursor-hover');
              // Show aperture + label
              var aperture = document.getElementById('cursor-aperture');
              var label = document.getElementById('cursor-label');
              if (aperture) aperture.style.opacity = '1';
              // Get location from filmstrip item data attribute
              var item = e.target.closest('.filmstrip-item');
              if (label && item) {
                var locationText = item.dataset.location || '';
                label.textContent = locationText;
                label.style.opacity = locationText ? '1' : '0';
              }
              // Animate aperture blades open
              animateAperture(true);
            } else {
              if (document.body.classList.contains('cursor-filmstrip')) {
                document.body.classList.remove('cursor-filmstrip');
                var aperture = document.getElementById('cursor-aperture');
                var label = document.getElementById('cursor-label');
                if (aperture) aperture.style.opacity = '0';
                if (label) { label.style.opacity = '0'; label.textContent = ''; }
                animateAperture(false);
              }
              document.body.classList.toggle('cursor-hover', isHover && !isFilmstrip);
            }
          }, { passive: true });

          // Aperture blade animation
          var apertureAngle = 60; // 60=closed, 0=open
          var apertureRaf = null;
          function animateAperture(opening) {
            if (apertureRaf) cancelAnimationFrame(apertureRaf);
            var target = opening ? 0 : 60;
            function step() {
              apertureAngle += (target - apertureAngle) * 0.12;
              if (Math.abs(apertureAngle - target) < 0.3) apertureAngle = target;
              drawBlades(apertureAngle);
              if (apertureAngle !== target) apertureRaf = requestAnimationFrame(step);
            }
            step();
          }

          function drawBlades(angleDeg) {
            var cx = 20, cy = 20, R_o = 17, R_i = 5.5, n = 6;
            var offset = angleDeg * Math.PI / 180;
            for (var i = 0; i < n; i++) {
              var a0 = (i * 60 - 20) * Math.PI / 180 + offset;
              var a1 = (i * 60 + 70) * Math.PI / 180 + offset;
              var ai0 = (i * 60 + 42) * Math.PI / 180 + offset;
              var ai1 = (i * 60 + 132) * Math.PI / 180 + offset;
              var p1x = cx + R_o * Math.cos(a0), p1y = cy + R_o * Math.sin(a0);
              var p2x = cx + R_o * Math.cos(a1), p2y = cy + R_o * Math.sin(a1);
              var p3x = cx + R_i * Math.cos(ai1), p3y = cy + R_i * Math.sin(ai1);
              var p4x = cx + R_i * Math.cos(ai0), p4y = cy + R_i * Math.sin(ai0);
              var el = document.getElementById('ap-blade-' + i);
              if (el) el.setAttribute('d',
                'M ' + p1x.toFixed(2) + ' ' + p1y.toFixed(2) +
                ' L ' + p2x.toFixed(2) + ' ' + p2y.toFixed(2) +
                ' L ' + p3x.toFixed(2) + ' ' + p3y.toFixed(2) +
                ' L ' + p4x.toFixed(2) + ' ' + p4y.toFixed(2) + ' Z'
              );
            }
          }
          drawBlades(60); // init closed

          document.addEventListener('mousedown', function() {
            if (!document.body.classList.contains('cursor-filmstrip')) {
              document.body.classList.add('cursor-click');
              document.body.classList.remove('cursor-hover');
            }
          });
          document.addEventListener('mouseup', function() {
            document.body.classList.remove('cursor-click');
          });
          document.addEventListener('mouseleave', function() { document.body.classList.add('cursor-hidden'); });
          document.addEventListener('mouseenter', function() { document.body.classList.remove('cursor-hidden'); });
        }

        // Run on first load
        init();

        // Re-run after every Astro View Transition (page swap)
        document.addEventListener('astro:page-load', init);
      })();

      // ── Image protection ──
      document.addEventListener('contextmenu', function(e) {
        if (e.target && e.target.tagName === 'IMG') {
          e.preventDefault();
        }
      }, true);
      document.addEventListener('dragstart', function(e) {
        if (e.target && e.target.tagName === 'IMG') {
          e.preventDefault();
        }
      }, true);
    </script>
  </body>
</html>
