---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { serializeJsonLd } from '../lib/jsonLd';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  dark?: boolean;
  /** Page-specific JSON-LD blocks (e.g. ImageObject for a collection page).
   *  Concatenated with the default Person + WebSite blocks. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Ryan | Visual Archive',
  description = 'A curated collection of photographic moments — shot on Nikon Zf, engineered with intention.',
  ogImage = 'https://cdn.sanity.io/images/z610fooo/production/e69f9258142218c5cd649a9c01d4fe89d0335563-6048x4032.jpg?auto=format&w=1200&q=85',
  ogType = 'website',
  dark = false,
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://ryanxugallery.com');
const siteUrl = (Astro.site ?? new URL('https://ryanxugallery.com')).toString().replace(/\/$/, '');

// ─── Default JSON-LD: Person (Ryan Xu) + WebSite ───
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Ryan Xu',
  url: siteUrl,
  jobTitle: 'Photographer',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'New York',
    addressRegion: 'NY',
    addressCountry: 'US',
  },
  sameAs: [
    'https://www.instagram.com/ryan_photoo/',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Ryan Xu — Visual Archive',
  url: siteUrl,
  inLanguage: 'en-US',
};

const pageJsonLd = jsonLd
  ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : [];
const allJsonLd = [personSchema, websiteSchema, ...pageJsonLd];

// ─── Optional hub link (rel=me + footer link) ───
// Driven by PUBLIC_HUB_URL env var. Hidden when not set.
const hubUrl = import.meta.env.PUBLIC_HUB_URL || '';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=3" sizes="32x32" />
    <link rel="shortcut icon" href="/favicon.ico?v=3" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Sanity CDN — every image on the site comes through here, so warm the TLS */}
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    {/* mapbox preconnect only on /travel */}
    {/* One combined request; dropped the unused Noto Sans SC (Chinese) family
        that was a ~91 KB render-blocking stylesheet for nothing. */}
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Mrs+Saint+Delafield&display=swap" rel="stylesheet" />
    {/* mapbox-gl CSS is only needed on /travel — loaded by that page's head, not globally */}

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#0A0A0A" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Ryan Xu | Visual Archive" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* ── rel=me linking to the personal info hub (IndieAuth / Mastodon-style) ── */}
    {hubUrl && <link rel="me" href={hubUrl} />}

    {/* ── Structured data: Person + WebSite + page-specific blocks ── */}
    {allJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={serializeJsonLd(schema)} />
    ))}

    {/* Page-specific <head> injections (preconnects, stylesheets) */}
    <slot name="head" />

    <!-- Astro View Transitions — smooth page navigation -->
    <ClientRouter />
  </head>

  <body class:list={[
    "min-h-screen font-sans antialiased overflow-x-hidden",
    dark ? "bg-[#0A0A0A] text-[#FDFDFB]" : "bg-white text-gray-900"
  ]} style="cursor: none;">
    <!-- Custom cursor — a minimal dot (no ring) -->
    <div id="cursor-dot" aria-hidden="true"></div>
    <!-- Contextual cursor label — shows e.g. "View Story" when hovering a
         work, so the affordance to open it is unmistakable on desktop. -->
    <span id="cursor-label" aria-hidden="true">View</span>

    <slot />

    <!-- Global image protection: prevent right-click, drag, long-press save, and print -->
    <style is:global>
      img {
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
        pointer-events: auto;
        -webkit-user-drag: none;
        -khtml-user-drag: none;
        -moz-user-drag: none;
        -o-user-drag: none;
      }

      /* Mobile-only: prevent rubber-band bounce on the body so atmospheric
         fixed elements (video, sunbeam, grid) don't drift on iOS, and stop
         double-tap zoom which fights the cinematic transitions. */
      html, body {
        overscroll-behavior-y: none;
      }
      /* Touch devices don't get hover, so they shouldn't pay for cursor:none */
      @media (hover: none) {
        body { touch-action: manipulation; }
      }

      /* When printing, hide all images so a Save → Print → PDF route doesn't
         yield clean copies. Show a watermark in their place. */
      @media print {
        img, video, canvas, svg { display: none !important; }
        body::before {
          content: "© Ryan Xu · ryanxugallery.com — viewing copy, not for distribution.";
          display: block;
          padding: 2rem;
          font-family: ui-monospace, monospace;
          font-size: 12px;
          color: #444;
        }
      }

      /* ═══════════════════════════════════════════════════════
       *  Directional Page Transition — "Card Stack" model
       *  — Forward (click into a page): NEW page slides UP from below
       *    (pops up on top of the current card)
       *  — Back (leave / return):        OLD page slides DOWN off screen
       *    (the top card falls, revealing the card behind)
       *  Compositor-only transforms; no blur/box-shadow → smooth even
       *  while leaving heavy pages (e.g. /travel with Mapbox).
       * ═══════════════════════════════════════════════════════ */

      /* ─────────────────────────────────────────────────
       *  Default root swap — no animation. Directional motion is opted into
       *  per-navigation via html[data-axis] (below): "enter" depth-zoom for
       *  Home→section, "forward"/"back" shared-axis push for Map↔About.
       *  Everything else (e.g. →Home via the DIY slide-down) swaps instantly.
       *  ───────────────────────────────────────────────── */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
      }

      /* ───────────────────────────────────────────────
       *  Lateral sibling nav (Map ↔ About) — shared-axis push.
       *
       *  Apple / Material-grade peer-tab transition: the incoming page
       *  slides in OPAQUE over the outgoing one, which parallax-drifts the
       *  other way and dims. No full-screen masthead — switching between
       *  two peer sections should feel like a continuous spatial move, not
       *  an interruption. Direction (`forward` / `back`) is set on <html>
       *  by JS from the route order, and re-asserted in astro:after-swap
       *  (Astro wipes root attributes during the DOM swap).
       *  ─────────────────────────────────────────────── */
      html[data-axis]::view-transition-old(root) { z-index: 1; }
      html[data-axis]::view-transition-new(root) { z-index: 2; }

      html[data-axis="forward"]::view-transition-old(root) {
        animation: sa-old-fwd 0.54s cubic-bezier(0.65, 0, 0.35, 1) both;
      }
      html[data-axis="forward"]::view-transition-new(root) {
        animation: sa-new-fwd 0.54s cubic-bezier(0.65, 0, 0.35, 1) both;
      }
      html[data-axis="back"]::view-transition-old(root) {
        animation: sa-old-back 0.54s cubic-bezier(0.65, 0, 0.35, 1) both;
      }
      html[data-axis="back"]::view-transition-new(root) {
        animation: sa-new-back 0.54s cubic-bezier(0.65, 0, 0.35, 1) both;
      }
      /* Whip/swish pan: both frames streak across with horizontal motion
         blur + a slight horizontal stretch, crossing blurred at mid-point
         then resolving — a fast camera pan between two scenes. */
      @keyframes sa-old-fwd  {
        0%   { transform: translateX(0)    scaleX(1);    opacity: 1; filter: blur(0); }
        100% { transform: translateX(-60%) scaleX(1.08); opacity: 0; filter: blur(20px); }
      }
      @keyframes sa-new-fwd  {
        0%   { transform: translateX(60%)  scaleX(1.08); opacity: 0; filter: blur(20px); }
        45%  { opacity: 1; }
        100% { transform: translateX(0)    scaleX(1);    opacity: 1; filter: blur(0); }
      }
      @keyframes sa-old-back {
        0%   { transform: translateX(0)    scaleX(1);    opacity: 1; filter: blur(0); }
        100% { transform: translateX(60%)  scaleX(1.08); opacity: 0; filter: blur(20px); }
      }
      @keyframes sa-new-back {
        0%   { transform: translateX(-60%) scaleX(1.08); opacity: 0; filter: blur(20px); }
        45%  { opacity: 1; }
        100% { transform: translateX(0)    scaleX(1);    opacity: 1; filter: blur(0); }
      }

      /* ───────────────────────────────────────────────
       *  Enter a section from Home (Home → Map / About) — Apple depth zoom.
       *
       *  A strong, intuitive "push forward into the destination": the new
       *  page rushes toward you, growing from smaller to full while fading
       *  in; the Home page recedes — scaling up past the camera and
       *  blurring out. Reads as moving INTO the content, not sliding next
       *  to it. (Map↔About stays lateral; this is descent into depth.)
       *  ─────────────────────────────────────────────── */
      html[data-axis="enter"]::view-transition-old(root) {
        /* Home rushes out — accelerating away, blowing up, over-exposing
           into a bright bloom as you punch through it. */
        animation: enter-old 0.8s cubic-bezier(0.7, 0, 0.84, 0) both;
        transform-origin: 50% 46%;
      }
      html[data-axis="enter"]::view-transition-new(root) {
        /* Destination warps in from far away with motion blur that clears,
           overshoots, then snaps to rest. */
        animation: enter-new 0.86s cubic-bezier(0.16, 1, 0.3, 1) both;
        transform-origin: 50% 46%;
      }
      @keyframes enter-old {
        0%   { opacity: 1; transform: scale(1);   filter: blur(0)    brightness(1); }
        100% { opacity: 0; transform: scale(1.6); filter: blur(22px) brightness(1.5); }
      }
      @keyframes enter-new {
        0%   { opacity: 0; transform: scale(0.55); filter: blur(16px) brightness(1.4) saturate(1.25); }
        45%  { opacity: 1; }
        80%  { opacity: 1; transform: scale(1.04); filter: blur(0)    brightness(1.08) saturate(1.04); }
        100% { opacity: 1; transform: scale(1);    filter: blur(0)    brightness(1)    saturate(1); }
      }

      /* Reduced-motion: disable the directional view transitions. */
      @media (prefers-reduced-motion: reduce) {
        html[data-axis]::view-transition-old(root),
        html[data-axis]::view-transition-new(root) {
          animation: none !important;
        }
      }

      /* Back-nav slide-down: applied to <body> via JS. Uses compositor-only
         `transform` so it stays smooth even with heavy pages (Mapbox etc.). */
      body.vt-back-exit {
        transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
        transform: translateY(100vh);
        will-change: transform;
      }

      /* Reduce motion: instant transition for accessibility */
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root) {
          animation: none;
        }
      }
    </style>

    <style is:inline>
      /* Hide default cursor everywhere except lightbox */
      *, *::before, *::after { cursor: none !important; }
      /* Lightbox: restore default cursor (custom cursor is hidden via cursor-hidden class) */
      .cursor-hidden ~ * { cursor: default; }
      [style*="cursor: default"], [style*="cursor: default"] * { cursor: default !important; }

      #cursor-dot {
        position: fixed;
        top: 0; left: 0;
        width: 7px; height: 7px;
        margin: -3.5px 0 0 -3.5px;
        background: white;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        will-change: left, top, transform;
        mix-blend-mode: difference;
        transition: transform 0.3s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.2s ease;
      }
      /* Over interactive elements the dot swells into a soft point; on press
         it tucks in — the affordance the ring used to carry, minus the ring. */
      body.cursor-hover #cursor-dot { transform: scale(2.4); }
      body.cursor-click #cursor-dot { transform: scale(1.3); }

      /* Contextual cursor label ("View Story", etc.) */
      #cursor-label {
        position: fixed;
        top: 0; left: 0;
        z-index: 9999;
        pointer-events: none;
        font-family: ui-monospace, monospace;
        font-size: 8.5px;
        letter-spacing: 0.28em;
        text-transform: uppercase;
        font-weight: 700;
        color: #0A0A0A;
        background: #FDFDFB;
        padding: 6px 11px;
        border-radius: 999px;
        white-space: nowrap;
        opacity: 0;
        transform: translate(14px, 14px) scale(0.7);
        transform-origin: top left;
        transition: opacity 0.22s ease, transform 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        will-change: left, top, transform, opacity;
      }
      body.cursor-label-on #cursor-label {
        opacity: 1;
        transform: translate(16px, 16px) scale(1);
      }

      body.cursor-hidden #cursor-dot { opacity: 0 !important; }
      body.cursor-hidden #cursor-label { opacity: 0 !important; }

      @media (hover: none) {
        #cursor-dot, #cursor-label { display: none !important; }
        *, *::before, *::after { cursor: auto !important; }
      }
    </style>

    <script is:inline>
      // ── Custom cursor (minimal dot + contextual label) ──
      (function() {
        var mouseX = -200, mouseY = -200;
        var initialized = false;

        function init() {
          var dot = document.getElementById('cursor-dot');
          if (!dot) return;

          document.body.classList.remove('cursor-hover', 'cursor-hidden', 'cursor-label-on', 'cursor-click');

          if (initialized) return;
          initialized = true;

          var hoverEls = 'a, button, [role="button"], .filmstrip-item, .work-photo-item, .cursor-pointer, input, textarea, select, label';

          document.addEventListener('mousemove', function(e) {
            mouseX = e.clientX;
            mouseY = e.clientY;
            var d = document.getElementById('cursor-dot');
            if (d) { d.style.left = mouseX + 'px'; d.style.top = mouseY + 'px'; }
            var isHover = !!(e.target && e.target.closest && e.target.closest(hoverEls));
            document.body.classList.toggle('cursor-hover', isHover);

            // Contextual label: when over a [data-cursor] element (a work),
            // show its prompt (e.g. "View Story") pinned to the cursor.
            var label = document.getElementById('cursor-label');
            if (label) {
              label.style.left = mouseX + 'px';
              label.style.top = mouseY + 'px';
              var ct = e.target && e.target.closest ? e.target.closest('[data-cursor]') : null;
              if (ct) {
                var txt = ct.getAttribute('data-cursor') || 'View';
                if (label.textContent !== txt) label.textContent = txt;
                document.body.classList.add('cursor-label-on');
              } else {
                document.body.classList.remove('cursor-label-on');
              }
            }
          }, { passive: true });

          document.addEventListener('mousedown', function() {
            document.body.classList.add('cursor-click');
          });
          document.addEventListener('mouseup', function() {
            document.body.classList.remove('cursor-click');
          });
          document.addEventListener('mouseleave', function() { document.body.classList.add('cursor-hidden'); });
          document.addEventListener('mouseenter', function() { document.body.classList.remove('cursor-hidden'); });
        }

        init();
        document.addEventListener('astro:page-load', init);
      })();

      // ── Image protection ──
      // Block right-click anywhere on a photo (img tag OR a container that
      // declares itself as wrapping a protected image via .work-photo-item /
      // [data-protected] / nodes inside the lightbox).
      function isProtectedTarget(t) {
        if (!t || !t.closest) return false;
        if (t.tagName === 'IMG') return true;
        return !!t.closest('img, .work-photo-item, [data-protected], #lightbox, .photo-cell');
      }
      document.addEventListener('contextmenu', function(e) {
        if (isProtectedTarget(e.target)) e.preventDefault();
      }, true);
      document.addEventListener('dragstart', function(e) {
        if (isProtectedTarget(e.target)) e.preventDefault();
      }, true);
      // Block Cmd/Ctrl + S (save page) and Cmd/Ctrl + P (print).
      // Power users can still bypass via DevTools — this is a deterrent
      // for casual saving, not a security boundary.
      document.addEventListener('keydown', function(e) {
        var mod = e.metaKey || e.ctrlKey;
        if (mod && (e.key === 's' || e.key === 'S' || e.key === 'p' || e.key === 'P')) {
          e.preventDefault();
        }
      }, true);

      // ── Back-nav slide-down (DIY, Framer-Motion exit={{y:"100%"}} pattern) ──
      // Why DIY: browsers' CSS View Transitions API proved unreliable for the
      // "old-page slides down while new-page holds" pattern across Astro's
      // ClientRouter swap. Instead, we cancel the ClientRouter navigation for
      // back-direction clicks, animate <body> down with a CSS transform, and
      // then do a normal navigation to the destination. The page beneath the
      // sliding body is the browser background — set to match the destination
      // (dark for home, light for light pages) so no jarring flash appears.
      //
      // Back detection:
      //   1. Browser back/forward button (popstate)
      //   2. Link click where dest is "/" or has fewer path segments
      (function() {
        var DUR = 550; // ms — must match CSS `body.vt-back-exit` transition
        var EXITING = false;

        function depth(path) { return path.split('/').filter(Boolean).length; }

        function pathOf(u) {
          if (!u) return '';
          if (typeof u === 'string') {
            try { return new URL(u, window.location.origin).pathname; }
            catch (e) { return u; }
          }
          return u.pathname || '';
        }

        function isBackTo(toPath) {
          if (!toPath) return false;
          if (toPath === '/') return true;
          return depth(toPath) < depth(window.location.pathname);
        }

        // Pick background color that will be revealed under the sliding body.
        // All pages use dark theme (#0A0A0A).
        function bgFor(toPath) {
          return '#0A0A0A';
        }

        function runExit(href, bg) {
          if (EXITING) return;
          EXITING = true;
          // Paint the background the destination page will use, so the strip
          // exposed beneath the sliding body is the right color.
          document.documentElement.style.backgroundColor = bg;
          document.body.style.backgroundColor = getComputedStyle(document.body).backgroundColor || '';
          // Kick the animation on the next frame so the transition has a
          // clean starting state (transform:none → translateY(100vh))
          requestAnimationFrame(function() {
            document.body.classList.add('vt-back-exit');
          });
          setTimeout(function() {
            // Full navigation — simpler than splicing into ClientRouter
            window.location.href = href;
          }, DUR + 20);
        }

        // 1) Intercept "back"-direction link clicks BEFORE Astro's ClientRouter
        //    handler fires. Listener added on `document` in capture phase runs
        //    earlier than ClientRouter's delegated click handler.
        document.addEventListener('click', function(e) {
          if (EXITING) { e.preventDefault(); return; }
          if (e.defaultPrevented) return;
          if (e.button !== 0) return;                 // only primary click
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
          var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
          if (!a) return;
          if (a.target && a.target !== '' && a.target !== '_self') return;
          if (a.hasAttribute('download')) return;
          var href = a.getAttribute('href');
          if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
          var url;
          try { url = new URL(href, window.location.origin); } catch (err) { return; }
          if (url.origin !== window.location.origin) return;
          var toPath = url.pathname;
          if (toPath === window.location.pathname) return;
          if (!isBackTo(toPath)) return;

          e.preventDefault();
          e.stopPropagation();
          runExit(url.pathname + url.search + url.hash, bgFor(toPath));
        }, true); // capture phase — run before ClientRouter

        // 2) Intercept browser Back/Forward button. `popstate` fires after
        //    the URL has already changed, so we push the original URL back,
        //    run the exit animation, then navigate for real.
        var _lastPath = window.location.pathname;
        window.addEventListener('popstate', function() {
          var toPath = window.location.pathname;
          if (!isBackTo.call(null, toPath)) { _lastPath = toPath; return; }
          if (EXITING) return;
          var target = window.location.href;
          // Undo the popstate so the visible URL reflects the page we're still showing.
          // We use replaceState with the _lastPath so history length stays sane.
          history.pushState(null, '', _lastPath);
          runExit(target, bgFor(toPath));
        });
      })();

      // ── Filmstrip scroll restoration ──
      // Save scroll position when leaving homepage; restore when returning
      document.addEventListener('astro:before-preparation', function(e) {
        if (window.location.pathname === '/') {
          sessionStorage.setItem('home-filmstrip-scroll', String(window.scrollY));
        }
      });
      document.addEventListener('astro:page-load', function() {
        if (window.location.pathname === '/') {
          var saved = sessionStorage.getItem('home-filmstrip-scroll');
          if (saved) {
            sessionStorage.removeItem('home-filmstrip-scroll');
            var y = parseInt(saved, 10);
            // Only restore if user was past the hero (i.e., in the filmstrip area)
            if (y > 100) {
              // Delay to allow React hydration before scrolling
              setTimeout(function() {
                window.scrollTo({ top: y, behavior: 'instant' });
              }, 120);
            }
          }
        }
      });

      // ── Page-transition direction (View Transitions) ──
      // Sets html[data-axis] from the route relationship so the global
      // ::view-transition(root) rules animate the right way:
      //   Home → Map/About : depth zoom ("enter")
      //   Map ↔ About      : shared-axis push ("forward" / "back")
      // (→Home is the DIY body slide-down; opening a story is the React
      // MagazineLayout cover — neither uses this.)
      (function() {
        function normalize(path) {
          if (!path) return '/';
          if (path.length > 1 && path.endsWith('/')) return path.slice(0, -1);
          return path;
        }

        // Route order for lateral sibling nav (Map ↔ About).
        var LATERAL = { '/travel': 1, '/about': 2 };
        var pendingAxis = null; // 'forward' | 'back' | 'enter'

        document.addEventListener('astro:before-preparation', function(e) {
          if (!(e && e.to)) return;
          var toPath = '';
          try { toPath = new URL(e.to, window.location.origin).pathname; }
          catch (err) { return; }
          var nf = normalize(window.location.pathname);
          var nt = normalize(toPath);
          document.documentElement.removeAttribute('data-axis');
          pendingAxis = null;
          if (nt === nf) return;

          // Arriving at About has its own editorial "contributor cover"
          // entrance (in AboutPage), so skip the root axis animation there —
          // no double reveal. (Leaving About still animates normally.)
          if (nt === '/about') return;

          // Lateral sibling nav (Map ↔ About): shared-axis push.
          if (LATERAL[nf] && LATERAL[nt]) {
            pendingAxis = LATERAL[nt] > LATERAL[nf] ? 'forward' : 'back';
            document.documentElement.setAttribute('data-axis', pendingAxis);
            return;
          }
          // Enter a section from Home (Home → Map / About): depth zoom.
          if (nf === '/' && LATERAL[nt]) {
            pendingAxis = 'enter';
            document.documentElement.setAttribute('data-axis', pendingAxis);
          }
        });

        // Astro wipes <html> attributes during the DOM swap, so the axis set
        // in before-preparation is gone by the time the browser computes the
        // ::view-transition animation. astro:after-swap runs synchronously
        // inside the view-transition update callback (after the attribute
        // wipe, before the new snapshot is styled) — re-assert it here.
        document.addEventListener('astro:after-swap', function() {
          if (pendingAxis) {
            document.documentElement.setAttribute('data-axis', pendingAxis);
          }
        });
      })();
    </script>
  </body>
</html>
