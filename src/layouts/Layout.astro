---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  dark?: boolean;
  /** Page-specific JSON-LD blocks (e.g. ImageObject for a collection page).
   *  Concatenated with the default Person + WebSite blocks. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Ryan | Visual Archive',
  description = 'A curated collection of photographic moments — shot on Nikon Zf, engineered with intention.',
  ogImage = 'https://cdn.sanity.io/images/z610fooo/production/e69f9258142218c5cd649a9c01d4fe89d0335563-6048x4032.jpg?auto=format&w=1200&q=85',
  ogType = 'website',
  dark = false,
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://ryanxugallery.com');
const siteUrl = (Astro.site ?? new URL('https://ryanxugallery.com')).toString().replace(/\/$/, '');

// ─── Default JSON-LD: Person (Ryan Xu) + WebSite ───
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Ryan Xu',
  url: siteUrl,
  jobTitle: 'Photographer',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'New York',
    addressRegion: 'NY',
    addressCountry: 'US',
  },
  sameAs: [
    'https://www.instagram.com/ryan_photoo/',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Ryan Xu — Visual Archive',
  url: siteUrl,
  inLanguage: 'en-US',
};

const pageJsonLd = jsonLd
  ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : [];
const allJsonLd = [personSchema, websiteSchema, ...pageJsonLd];

// ─── Optional hub link (rel=me + footer link) ───
// Driven by PUBLIC_HUB_URL env var. Hidden when not set.
const hubUrl = import.meta.env.PUBLIC_HUB_URL || '';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=3" sizes="32x32" />
    <link rel="shortcut icon" href="/favicon.ico?v=3" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Sanity CDN — every image on the site comes through here, so warm the TLS */}
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    {/* mapbox preconnect only on /travel */}
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Mrs+Saint+Delafield&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet" />
    {/* mapbox-gl CSS is only needed on /travel — loaded by that page's head, not globally */}

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#0A0A0A" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Ryan Xu | Visual Archive" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* ── rel=me linking to the personal info hub (IndieAuth / Mastodon-style) ── */}
    {hubUrl && <link rel="me" href={hubUrl} />}

    {/* ── Structured data: Person + WebSite + page-specific blocks ── */}
    {allJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    {/* Page-specific <head> injections (preconnects, stylesheets) */}
    <slot name="head" />

    <!-- Astro View Transitions — smooth page navigation -->
    <ClientRouter />
  </head>

  <body class:list={[
    "min-h-screen font-sans antialiased overflow-x-hidden",
    dark ? "bg-[#0A0A0A] text-[#FDFDFB]" : "bg-white text-gray-900"
  ]} style="cursor: none;">
    <!-- Custom cursor -->
    <div id="cursor-dot" aria-hidden="true"></div>
    <!-- Liquid ring: SVG ellipse that stretches with velocity -->
    <svg id="cursor-ring" aria-hidden="true"
      viewBox="0 0 40 40"
      xmlns="http://www.w3.org/2000/svg"
      style="position:fixed;top:0;left:0;width:40px;height:40px;pointer-events:none;z-index:9998;overflow:visible;mix-blend-mode:difference;opacity:0.55">
      <ellipse id="cursor-ellipse" cx="20" cy="20" rx="18" ry="18"
        fill="none" stroke="white" stroke-width="1"/>
    </svg>

    <!-- Editorial "press sheet" page transition — a printed spread that
         rises to cover the viewport, sets its masthead + headline + column
         rules like a magazine being laid out, then lifts up and away to
         reveal the new page. JS adds .pt-active (entrance/hold) then
         .pt-exit (lift-away) to this node. Content is repopulated
         per-destination via the [data-pt-*] nodes before the entrance.

         transition:persist — the SAME DOM node is carried across Astro's
         body swap, so its mid-flight class state (pt-active) survives and
         the sheet can lift away *after* the swap instead of vanishing with
         the old body. State is driven by classes ON THIS ELEMENT, never a
         body attribute (which the swap would discard). -->
    <div id="page-transition" aria-hidden="true" transition:persist="page-transition">
      {/* Newsprint halftone screen — the "printed page" grain */}
      <div class="pt-grain newsprint-screen" aria-hidden="true"></div>
      {/* Newspaper column rules drawn behind the editorial block */}
      <div class="pt-columns" aria-hidden="true">
        <span></span><span></span><span></span><span></span>
      </div>

      {/* Running head / masthead */}
      <div class="pt-masthead">
        <span class="pt-mast-name">The Journal Gallery</span>
        <span class="pt-mast-edition" data-pt-edition>Edition</span>
      </div>

      {/* Center editorial block */}
      <div class="pt-stage">
        <span class="pt-kicker" data-pt-kicker>// section</span>
        <h1 class="pt-headline"><span class="pt-headline-inner" data-pt-title>Journal Gallery</span></h1>
        <div class="pt-dateline">
          <span data-pt-meta-a>Index</span>
          <span class="pt-dateline-dot"></span>
          <span data-pt-meta-b>Home</span>
        </div>
      </div>

      {/* Folio / page number */}
      <div class="pt-folio">
        <span class="pt-folio-no" data-pt-folio>00</span>
        <span class="pt-folio-label">Turning the page</span>
      </div>
    </div>

    <slot />

    <!-- Global image protection: prevent right-click, drag, long-press save, and print -->
    <style is:global>
      img {
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
        pointer-events: auto;
        -webkit-user-drag: none;
        -khtml-user-drag: none;
        -moz-user-drag: none;
        -o-user-drag: none;
      }

      /* Mobile-only: prevent rubber-band bounce on the body so atmospheric
         fixed elements (video, sunbeam, grid) don't drift on iOS, and stop
         double-tap zoom which fights the cinematic transitions. */
      html, body {
        overscroll-behavior-y: none;
      }
      /* Touch devices don't get hover, so they shouldn't pay for cursor:none */
      @media (hover: none) {
        body { touch-action: manipulation; }
      }

      /* When printing, hide all images so a Save → Print → PDF route doesn't
         yield clean copies. Show a watermark in their place. */
      @media print {
        img, video, canvas, svg { display: none !important; }
        body::before {
          content: "© Ryan Xu · ryanxugallery.com — viewing copy, not for distribution.";
          display: block;
          padding: 2rem;
          font-family: ui-monospace, monospace;
          font-size: 12px;
          color: #444;
        }
      }

      /* ═══════════════════════════════════════════════════════
       *  Directional Page Transition — "Card Stack" model
       *  — Forward (click into a page): NEW page slides UP from below
       *    (pops up on top of the current card)
       *  — Back (leave / return):        OLD page slides DOWN off screen
       *    (the top card falls, revealing the card behind)
       *  Compositor-only transforms; no blur/box-shadow → smooth even
       *  while leaving heavy pages (e.g. /travel with Mapbox).
       * ═══════════════════════════════════════════════════════ */

      /* ─────────────────────────────────────────────────
       *  Forward nav — root swap stays invisible.
       *
       *  The editorial "press sheet" overlay (below) fully covers the
       *  viewport during the DOM swap, so the underlying ::view-transition
       *  fade only needs to be instant — no competing cross-fade.
       *  ───────────────────────────────────────────────── */
      ::view-transition-old(root),
      ::view-transition-new(root) {
        animation: none;
        mix-blend-mode: normal;
      }

      /* ═══════════════════════════════════════════════════════
       *  Editorial "press sheet" transition
       *
       *  A printed magazine spread that travels UP through the viewport
       *  in one continuous motion across the whole navigation:
       *    1. ENTRANCE  — rises from the bottom edge to cover the screen
       *                   (.pt-active); as it settles it "sets" the
       *                   masthead, column rules, kinetic headline and
       *                   folio like a page being laid out.
       *    2. HOLD      — Astro swaps the DOM behind the opaque sheet.
       *    3. LIFT-AWAY — the sheet continues upward and off the top edge
       *                   (.pt-exit), revealing the new page
       *                   beneath. One direction of travel → reads fluid,
       *                   not a yo-yo fade.
       *
       *  Back nav uses the DIY body-slide-down path (a fast return), so it
       *  deliberately skips this sheet.
       * ═══════════════════════════════════════════════════════ */
      #page-transition {
        position: fixed;
        inset: 0;
        z-index: 9999;
        pointer-events: none;
        overflow: hidden;
        background: #0A0A0A;
        color: #FDFDFB;
        visibility: hidden;
        transform: translateY(100%);
        transition:
          transform 0.62s cubic-bezier(0.76, 0, 0.24, 1),
          visibility 0s linear 0.62s;
      }
      /* Faint paper-edge hairlines top & bottom of the sheet */
      #page-transition::after {
        content: '';
        position: absolute;
        left: 0; right: 0; top: 0;
        height: 100%;
        border-top: 1px solid rgba(255, 255, 255, 0.12);
        border-bottom: 1px solid rgba(255, 255, 255, 0.12);
        pointer-events: none;
      }
      /* Newsprint halftone screen overlaying the whole sheet */
      .pt-grain {
        position: absolute;
        inset: 0;
        opacity: 0.06;
        pointer-events: none;
        z-index: 1;
      }
      /* Accent wash bottom-left, tied to the homepage color identity */
      #page-transition::before {
        content: '';
        position: absolute;
        inset: 0;
        background: radial-gradient(
          50vmax 40vmax at 18% 110%,
          rgba(var(--accent-r, 255), var(--accent-g, 255), var(--accent-b, 255), 0.10),
          transparent 68%
        );
        opacity: 0;
        transition: opacity 0.7s ease-out 0.08s;
      }
      #page-transition.pt-active {
        visibility: visible;
        transform: translateY(0);
        transition:
          transform 0.62s cubic-bezier(0.22, 1, 0.36, 1),
          visibility 0s linear 0s;
      }
      #page-transition.pt-active::before { opacity: 1; }

      /* LIFT-AWAY — continue travelling up and off the top */
      #page-transition.pt-exit {
        visibility: visible;
        transform: translateY(-100%);
        transition:
          transform 0.72s cubic-bezier(0.76, 0, 0.24, 1),
          visibility 0s linear 0.72s;
      }

      /* Instant reset — used to snap the sheet back to its parked state
         after the lift-away without animating it back down through view. */
      #page-transition.pt-instant,
      #page-transition.pt-instant *,
      #page-transition.pt-instant::before {
        transition: none !important;
      }

      /* ── Newspaper column rules ── */
      .pt-columns {
        position: absolute;
        inset: 0;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        opacity: 0.5;
        pointer-events: none;
      }
      .pt-columns span {
        border-right: 1px solid rgba(255, 255, 255, 0.05);
        transform: scaleY(0);
        transform-origin: top;
        transition: transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
      }
      .pt-columns span:last-child { border-right: 0; }
      .pt-columns span:nth-child(1) { transition-delay: 0.06s; }
      .pt-columns span:nth-child(2) { transition-delay: 0.12s; }
      .pt-columns span:nth-child(3) { transition-delay: 0.18s; }
      .pt-columns span:nth-child(4) { transition-delay: 0.24s; }
      #page-transition.pt-active .pt-columns span { transform: scaleY(1); }

      /* ── Masthead / running head ── */
      .pt-masthead {
        position: absolute;
        top: clamp(1.5rem, 4vh, 3rem);
        left: clamp(1.5rem, 5vw, 4rem);
        right: clamp(1.5rem, 5vw, 4rem);
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        padding-bottom: 0.9rem;
        border-bottom: 3px double rgba(255, 255, 255, 0.22);
        font-family: ui-monospace, monospace;
        font-size: 10px;
        letter-spacing: 0.42em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.55);
        /* draw the rule from the left */
        clip-path: inset(0 100% 0 0);
        transition: clip-path 0.65s cubic-bezier(0.22, 1, 0.36, 1) 0.05s;
      }
      .pt-masthead .pt-mast-name { font-weight: 500; }
      .pt-masthead .pt-mast-edition { color: rgba(255, 255, 255, 0.35); }
      #page-transition.pt-active .pt-masthead { clip-path: inset(0 0 0 0); }

      /* ── Center editorial block ── */
      .pt-stage {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 1.4rem;
        padding: 0 6vw;
        text-align: center;
      }

      .pt-kicker {
        font-family: ui-monospace, monospace;
        font-size: 11px;
        letter-spacing: 0.5em;
        text-transform: uppercase;
        color: rgba(var(--accent-r, 255), var(--accent-g, 255), var(--accent-b, 255), 0.85);
        opacity: 0;
        transform: translateY(10px);
        transition:
          opacity 0.5s ease-out 0.22s,
          transform 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.22s;
      }
      #page-transition.pt-active .pt-kicker { opacity: 1; transform: translateY(0); }

      /* Headline rises out of a baseline mask, like type being set */
      .pt-headline {
        margin: 0;
        overflow: hidden;
        padding: 0.04em 0.02em;
      }
      .pt-headline-inner {
        display: inline-block;
        font-family: 'Instrument Serif', serif;
        font-style: italic;
        font-weight: 400;
        font-size: clamp(52px, 13vw, 200px);
        line-height: 0.92;
        letter-spacing: -0.02em;
        color: rgba(255, 255, 255, 0.98);
        transform: translateY(110%);
        transition: transform 0.85s cubic-bezier(0.16, 1, 0.3, 1) 0.18s;
      }
      #page-transition.pt-active .pt-headline-inner { transform: translateY(0); }

      .pt-dateline {
        display: flex;
        align-items: center;
        gap: 1rem;
        font-family: ui-monospace, monospace;
        font-size: 10px;
        letter-spacing: 0.34em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.4);
        opacity: 0;
        transform: translateY(10px);
        transition:
          opacity 0.5s ease-out 0.36s,
          transform 0.6s cubic-bezier(0.22, 1, 0.36, 1) 0.36s;
      }
      #page-transition.pt-active .pt-dateline { opacity: 1; transform: translateY(0); }
      .pt-dateline-dot {
        width: 3px; height: 3px; border-radius: 50%;
        background: rgba(var(--accent-r, 255), var(--accent-g, 255), var(--accent-b, 255), 0.7);
      }

      /* ── Folio / page number ── */
      .pt-folio {
        position: absolute;
        bottom: clamp(1.5rem, 4vh, 3rem);
        left: clamp(1.5rem, 5vw, 4rem);
        right: clamp(1.5rem, 5vw, 4rem);
        display: flex;
        align-items: baseline;
        justify-content: space-between;
        gap: 1rem;
        padding-top: 0.9rem;
        border-top: 3px double rgba(255, 255, 255, 0.22);
        font-family: ui-monospace, monospace;
        font-size: 10px;
        letter-spacing: 0.42em;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.35);
        clip-path: inset(0 0 0 100%);
        transition: clip-path 0.65s cubic-bezier(0.22, 1, 0.36, 1) 0.12s;
      }
      .pt-folio .pt-folio-no {
        font-size: 13px;
        letter-spacing: 0.2em;
        color: rgba(255, 255, 255, 0.55);
      }
      #page-transition.pt-active .pt-folio { clip-path: inset(0 0 0 0); }

      /* Reduced-motion: instant cover/reveal, no travel or stagger. */
      @media (prefers-reduced-motion: reduce) {
        #page-transition,
        .pt-columns span,
        .pt-masthead,
        .pt-kicker,
        .pt-headline-inner,
        .pt-dateline,
        .pt-folio,
        #page-transition::before {
          transition-duration: 0.01s !important;
          transition-delay: 0s !important;
        }
      }

      /* Back-nav slide-down: applied to <body> via JS. Uses compositor-only
         `transform` so it stays smooth even with heavy pages (Mapbox etc.). */
      body.vt-back-exit {
        transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
        transform: translateY(100vh);
        will-change: transform;
      }

      /* Reduce motion: instant transition for accessibility */
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root) {
          animation: none;
        }
      }
    </style>

    <style is:inline>
      /* Hide default cursor everywhere except lightbox */
      *, *::before, *::after { cursor: none !important; }
      /* Lightbox: restore default cursor (custom cursor is hidden via cursor-hidden class) */
      .cursor-hidden ~ * { cursor: default; }
      [style*="cursor: default"], [style*="cursor: default"] * { cursor: default !important; }

      #cursor-dot {
        position: fixed;
        top: 0; left: 0;
        width: 5px; height: 5px;
        margin: -2.5px 0 0 -2.5px;
        background: white;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        will-change: left, top;
        mix-blend-mode: difference;
      }

      /* Ring is now an SVG — positioned and shaped via JS */
      #cursor-ring { will-change: left, top; }

      body.cursor-hidden #cursor-ring { opacity: 0 !important; }
      body.cursor-hidden #cursor-dot,
      body.cursor-hidden #cursor-ring { opacity: 0 !important; }

      @media (hover: none) {
        #cursor-dot, #cursor-ring { display: none !important; }
        *, *::before, *::after { cursor: auto !important; }
      }
    </style>

    <script is:inline>
      // ── Custom cursor (liquid deformation) ──
      (function() {
        var mouseX = -200, mouseY = -200;
        var ringX  = -200, ringY  = -200;
        var prevMouseX = -200, prevMouseY = -200;
        var velX = 0, velY = 0;
        var rxVal = 18, ryVal = 18, angleVal = 0;
        var raf = null;
        var initialized = false;
        var isClick = false;

        function lerp(a, b, t) { return a + (b - a) * t; }

        function init() {
          var dot  = document.getElementById('cursor-dot');
          var ring = document.getElementById('cursor-ring');
          var ellipse = document.getElementById('cursor-ellipse');
          if (!dot || !ring || !ellipse) return;

          if (raf) { cancelAnimationFrame(raf); raf = null; }
          document.body.classList.remove('cursor-hover', 'cursor-hidden');

          function loop() {
            // Smooth ring position
            ringX = lerp(ringX, mouseX, 0.13);
            ringY = lerp(ringY, mouseY, 0.13);

            // Velocity-based deformation
            velX = lerp(velX, mouseX - prevMouseX, 0.25);
            velY = lerp(velY, mouseY - prevMouseY, 0.25);
            prevMouseX = lerp(prevMouseX, mouseX, 0.25);
            prevMouseY = lerp(prevMouseY, mouseY, 0.25);

            var speed = Math.sqrt(velX * velX + velY * velY);

            // Stretch amount: faster = more elongated
            var stretch = Math.min(speed * 0.55, 10);
            var targetRx, targetRy, targetAngle;

            if (isClick) {
              targetRx = 11; targetRy = 11; targetAngle = 0;
            } else {
              targetRx = 18 + stretch;
              targetRy = Math.max(18 - stretch * 0.5, 9);
              // Angle follows velocity direction
              targetAngle = speed > 0.5 ? Math.atan2(velY, velX) * 180 / Math.PI : angleVal;
            }

            rxVal    = lerp(rxVal,    targetRx,    0.18);
            ryVal    = lerp(ryVal,    targetRy,    0.18);
            angleVal = lerp(angleVal, targetAngle, 0.14);

            // Position: center the SVG on cursor
            ring.style.left = (ringX - 20) + 'px';
            ring.style.top  = (ringY - 20) + 'px';

            // Apply deformation to ellipse
            ellipse.setAttribute('rx', rxVal.toFixed(2));
            ellipse.setAttribute('ry', ryVal.toFixed(2));
            ring.style.transformOrigin = '20px 20px';
            ring.style.transform = 'rotate(' + angleVal.toFixed(1) + 'deg)';

            // Opacity: normal 0.5, hover 0.3
            var targetOpacity = document.body.classList.contains('cursor-hover') ? '0.3' : '0.5';
            ring.style.opacity = targetOpacity;

            raf = requestAnimationFrame(loop);
          }
          loop();

          if (initialized) return;
          initialized = true;

          var hoverEls = 'a, button, [role="button"], .filmstrip-item, .work-photo-item, .cursor-pointer, input, textarea, select, label';

          document.addEventListener('mousemove', function(e) {
            mouseX = e.clientX;
            mouseY = e.clientY;
            var d = document.getElementById('cursor-dot');
            if (d) { d.style.left = mouseX + 'px'; d.style.top = mouseY + 'px'; }
            var isHover = !!(e.target && e.target.closest && e.target.closest(hoverEls));
            document.body.classList.toggle('cursor-hover', isHover);
          }, { passive: true });

          document.addEventListener('mousedown', function() {
            isClick = true;
            document.body.classList.add('cursor-click');
          });
          document.addEventListener('mouseup', function() {
            isClick = false;
            document.body.classList.remove('cursor-click');
          });
          document.addEventListener('mouseleave', function() { document.body.classList.add('cursor-hidden'); });
          document.addEventListener('mouseenter', function() { document.body.classList.remove('cursor-hidden'); });
        }

        init();
        document.addEventListener('astro:page-load', init);
      })();

      // ── Image protection ──
      // Block right-click anywhere on a photo (img tag OR a container that
      // declares itself as wrapping a protected image via .work-photo-item /
      // [data-protected] / nodes inside the lightbox).
      function isProtectedTarget(t) {
        if (!t || !t.closest) return false;
        if (t.tagName === 'IMG') return true;
        return !!t.closest('img, .work-photo-item, [data-protected], #lightbox, .photo-cell');
      }
      document.addEventListener('contextmenu', function(e) {
        if (isProtectedTarget(e.target)) e.preventDefault();
      }, true);
      document.addEventListener('dragstart', function(e) {
        if (isProtectedTarget(e.target)) e.preventDefault();
      }, true);
      // Block Cmd/Ctrl + S (save page) and Cmd/Ctrl + P (print).
      // Power users can still bypass via DevTools — this is a deterrent
      // for casual saving, not a security boundary.
      document.addEventListener('keydown', function(e) {
        var mod = e.metaKey || e.ctrlKey;
        if (mod && (e.key === 's' || e.key === 'S' || e.key === 'p' || e.key === 'P')) {
          e.preventDefault();
        }
      }, true);

      // ── Back-nav slide-down (DIY, Framer-Motion exit={{y:"100%"}} pattern) ──
      // Why DIY: browsers' CSS View Transitions API proved unreliable for the
      // "old-page slides down while new-page holds" pattern across Astro's
      // ClientRouter swap. Instead, we cancel the ClientRouter navigation for
      // back-direction clicks, animate <body> down with a CSS transform, and
      // then do a normal navigation to the destination. The page beneath the
      // sliding body is the browser background — set to match the destination
      // (dark for home, light for light pages) so no jarring flash appears.
      //
      // Back detection:
      //   1. Browser back/forward button (popstate)
      //   2. Link click where dest is "/" or has fewer path segments
      (function() {
        var DUR = 550; // ms — must match CSS `body.vt-back-exit` transition
        var EXITING = false;

        function depth(path) { return path.split('/').filter(Boolean).length; }

        function pathOf(u) {
          if (!u) return '';
          if (typeof u === 'string') {
            try { return new URL(u, window.location.origin).pathname; }
            catch (e) { return u; }
          }
          return u.pathname || '';
        }

        function isBackTo(toPath) {
          if (!toPath) return false;
          if (toPath === '/') return true;
          return depth(toPath) < depth(window.location.pathname);
        }

        // Pick background color that will be revealed under the sliding body.
        // All pages use dark theme (#0A0A0A).
        function bgFor(toPath) {
          return '#0A0A0A';
        }

        function runExit(href, bg) {
          if (EXITING) return;
          EXITING = true;
          // Paint the background the destination page will use, so the strip
          // exposed beneath the sliding body is the right color.
          document.documentElement.style.backgroundColor = bg;
          document.body.style.backgroundColor = getComputedStyle(document.body).backgroundColor || '';
          // Kick the animation on the next frame so the transition has a
          // clean starting state (transform:none → translateY(100vh))
          requestAnimationFrame(function() {
            document.body.classList.add('vt-back-exit');
          });
          setTimeout(function() {
            // Full navigation — simpler than splicing into ClientRouter
            window.location.href = href;
          }, DUR + 20);
        }

        // 1) Intercept "back"-direction link clicks BEFORE Astro's ClientRouter
        //    handler fires. Listener added on `document` in capture phase runs
        //    earlier than ClientRouter's delegated click handler.
        document.addEventListener('click', function(e) {
          if (EXITING) { e.preventDefault(); return; }
          if (e.defaultPrevented) return;
          if (e.button !== 0) return;                 // only primary click
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
          var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
          if (!a) return;
          if (a.target && a.target !== '' && a.target !== '_self') return;
          if (a.hasAttribute('download')) return;
          var href = a.getAttribute('href');
          if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
          var url;
          try { url = new URL(href, window.location.origin); } catch (err) { return; }
          if (url.origin !== window.location.origin) return;
          var toPath = url.pathname;
          if (toPath === window.location.pathname) return;
          if (!isBackTo(toPath)) return;

          e.preventDefault();
          e.stopPropagation();
          runExit(url.pathname + url.search + url.hash, bgFor(toPath));
        }, true); // capture phase — run before ClientRouter

        // 2) Intercept browser Back/Forward button. `popstate` fires after
        //    the URL has already changed, so we push the original URL back,
        //    run the exit animation, then navigate for real.
        var _lastPath = window.location.pathname;
        window.addEventListener('popstate', function() {
          var toPath = window.location.pathname;
          if (!isBackTo.call(null, toPath)) { _lastPath = toPath; return; }
          if (EXITING) return;
          var target = window.location.href;
          // Undo the popstate so the visible URL reflects the page we're still showing.
          // We use replaceState with the _lastPath so history length stays sane.
          history.pushState(null, '', _lastPath);
          runExit(target, bgFor(toPath));
        });
      })();

      // ── Filmstrip scroll restoration ──
      // Save scroll position when leaving homepage; restore when returning
      document.addEventListener('astro:before-preparation', function(e) {
        if (window.location.pathname === '/') {
          sessionStorage.setItem('home-filmstrip-scroll', String(window.scrollY));
        }
      });
      document.addEventListener('astro:page-load', function() {
        if (window.location.pathname === '/') {
          var saved = sessionStorage.getItem('home-filmstrip-scroll');
          if (saved) {
            sessionStorage.removeItem('home-filmstrip-scroll');
            var y = parseInt(saved, 10);
            // Only restore if user was past the hero (i.e., in the filmstrip area)
            if (y > 100) {
              // Delay to allow React hydration before scrolling
              setTimeout(function() {
                window.scrollTo({ top: y, behavior: 'instant' });
              }, 120);
            }
          }
        }
      });

      // ── Editorial "press sheet" transition choreography ──
      // On forward nav, populate the sheet with the destination's editorial
      // identity and add .pt-active to the (persisted) #page-transition node,
      // which raises the sheet from the bottom and "sets" the masthead /
      // headline / folio. Astro swaps the DOM behind the opaque sheet — and
      // because the node uses transition:persist, the SAME element (with its
      // .pt-active class) survives the swap. After astro:page-load (new DOM
      // ready) — but never before a minimum hold so the editorial beat always
      // plays — we add .pt-exit which lifts the sheet up and off the top,
      // revealing the new page, then reset it to its parked state.
      // Skip on back-nav (handled by body.vt-back-exit) and same-route clicks.
      (function() {
        // Destination metadata. Each entry drives one editorial sheet.
        // Keys match `new URL(href).pathname` (trailing-slash normalized).
        var DEST = {
          '/':       { kicker: '// the index',     title: 'Journal Gallery', a: 'Volume',  b: 'Complete Works', edition: 'Home Edition', folio: '01' },
          '/about':  { kicker: '// the operator',  title: 'Ryan Xu',         a: 'Profile', b: 'New York',       edition: 'The Profile',  folio: '02' },
          '/travel': { kicker: '// the territory', title: 'Geo · Map',       a: 'Atlas',   b: 'United States',  edition: 'Field Notes',  folio: '03' },
        };

        var MIN_HOLD = 820; // ms — guarantees the editorial reveal completes

        function normalize(path) {
          if (!path) return '/';
          if (path.length > 1 && path.endsWith('/')) return path.slice(0, -1);
          return path;
        }

        function metaFor(pathname) {
          return DEST[normalize(pathname)] || null;
        }

        function set(sel, val) {
          var el = document.querySelector(sel);
          if (el) el.textContent = val;
        }

        function populate(meta) {
          set('[data-pt-kicker]', meta.kicker);
          set('[data-pt-title]', meta.title);
          set('[data-pt-meta-a]', meta.a);
          set('[data-pt-meta-b]', meta.b);
          set('[data-pt-edition]', meta.edition);
          set('[data-pt-folio]', meta.folio);
        }

        var safetyTimer = null;
        var startedAt = 0;
        var active = false;

        function sheet() { return document.getElementById('page-transition'); }

        function startTransition(toPath) {
          var meta = metaFor(toPath);
          if (!meta) return; // unknown destination — skip the sheet
          var el = sheet();
          if (!el) return;
          populate(meta);
          active = true;
          startedAt = Date.now();
          // rAF so the populated text paints at its hidden start state
          // before the class flip triggers the entrance.
          requestAnimationFrame(function() {
            el.classList.remove('pt-instant', 'pt-exit');
            el.classList.add('pt-active');
          });
          clearTimeout(safetyTimer);
          safetyTimer = setTimeout(clearAll, 4500); // failsafe
        }

        function clearAll() {
          var el = sheet();
          active = false;
          clearTimeout(safetyTimer);
          if (!el) return;
          // Snap back to the parked state WITHOUT animating the sheet back
          // down through the viewport: kill transitions, drop the state
          // classes, then re-enable transitions a couple of frames later.
          el.classList.add('pt-instant');
          el.classList.remove('pt-active', 'pt-exit');
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              el.classList.remove('pt-instant');
            });
          });
        }

        function endTransition() {
          if (!active) return;
          var elapsed = Date.now() - startedAt;
          var wait = Math.max(MIN_HOLD - elapsed, 0);
          // Two rAF ticks so the new page has painted under the opaque
          // sheet, then honour the minimum hold, then lift the sheet away.
          requestAnimationFrame(function() {
            requestAnimationFrame(function() {
              setTimeout(function() {
                var el = sheet();
                if (el) {
                  el.classList.remove('pt-active');
                  el.classList.add('pt-exit');
                }
                // Clear once the lift-away travel (0.72s) finishes.
                setTimeout(clearAll, 760);
              }, wait);
            });
          });
        }

        // Astro forward nav. e.to is the destination URL.
        document.addEventListener('astro:before-preparation', function(e) {
          if (e && e.to) {
            var toPath = '';
            try { toPath = new URL(e.to, window.location.origin).pathname; }
            catch (err) { return; }
            // Skip same-route clicks and BACK-direction nav (depth
            // decreasing, or to home) — back uses the body slide-down.
            if (toPath === window.location.pathname) return;
            var depth = function(p) { return p.split('/').filter(Boolean).length; };
            if (depth(toPath) < depth(window.location.pathname) || toPath === '/') return;
            startTransition(toPath);
          }
        });
        document.addEventListener('astro:page-load', endTransition);
      })();
    </script>
  </body>
</html>
