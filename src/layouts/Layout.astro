---
import Nav from '../components/Nav';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Ryan | Visual Archive',
  description = 'A curated collection of photographic moments — shot on Nikon Zf, engineered with intention.',
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link href="https://api.mapbox.com/mapbox-gl-js/v3.4.0/mapbox-gl.css" rel="stylesheet" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>

  <body class="bg-white min-h-screen text-gray-900 font-sans antialiased overflow-x-hidden">
    <Nav client:load currentPath={currentPath} />

    <!-- Page content (with top padding for fixed nav) -->
    <div class="pt-16">
      <slot />
    </div>

    <!-- Footer -->
    <footer class="py-20 px-6 md:px-16 max-w-7xl mx-auto border-t border-gray-100 mt-12">
      <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
          <h2 class="text-lg font-light text-gray-900 tracking-tight">Visual Archive.</h2>
          <p class="text-xs text-gray-400 mt-1 font-light">
            &copy; {new Date().getFullYear()} Ryan. All rights reserved.
          </p>
        </div>
        <div class="flex items-center gap-6 text-xs text-gray-400 font-mono">
          <span>Nikon Zf</span>
          <span class="text-gray-200">|</span>
          <span>Astro + React</span>
          <span class="text-gray-200">|</span>
          <span>Sanity CMS</span>
        </div>
      </div>
    </footer>
  </body>
</html>
