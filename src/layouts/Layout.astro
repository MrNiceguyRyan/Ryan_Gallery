---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
  dark?: boolean;
  /** Page-specific JSON-LD blocks (e.g. ImageObject for a collection page).
   *  Concatenated with the default Person + WebSite blocks. */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title = 'Ryan | Visual Archive',
  description = 'A curated collection of photographic moments — shot on Nikon Zf, engineered with intention.',
  ogImage = 'https://cdn.sanity.io/images/z610fooo/production/e69f9258142218c5cd649a9c01d4fe89d0335563-6048x4032.jpg?auto=format&w=1200&q=85',
  ogType = 'website',
  dark = false,
  jsonLd,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://ryanxugallery.com');
const siteUrl = (Astro.site ?? new URL('https://ryanxugallery.com')).toString().replace(/\/$/, '');

// ─── Default JSON-LD: Person (Ryan Xu) + WebSite ───
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Ryan Xu',
  url: siteUrl,
  jobTitle: 'Photographer',
  address: {
    '@type': 'PostalAddress',
    addressLocality: 'New York',
    addressRegion: 'NY',
    addressCountry: 'US',
  },
  sameAs: [
    'https://www.instagram.com/ryan_photoo/',
  ],
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Ryan Xu — Visual Archive',
  url: siteUrl,
  inLanguage: 'en-US',
};

const pageJsonLd = jsonLd
  ? (Array.isArray(jsonLd) ? jsonLd : [jsonLd])
  : [];
const allJsonLd = [personSchema, websiteSchema, ...pageJsonLd];

// ─── Optional hub link (rel=me + footer link) ───
// Driven by PUBLIC_HUB_URL env var. Hidden when not set.
const hubUrl = import.meta.env.PUBLIC_HUB_URL || '';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=3" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=3" sizes="32x32" />
    <link rel="shortcut icon" href="/favicon.ico?v=3" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    {/* Sanity CDN — every image on the site comes through here, so warm the TLS */}
    <link rel="preconnect" href="https://cdn.sanity.io" crossorigin />
    {/* mapbox preconnect only on /travel */}
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Mrs+Saint+Delafield&family=Noto+Sans+SC:wght@300;400;500&display=swap" rel="stylesheet" />
    {/* mapbox-gl CSS is only needed on /travel — loaded by that page's head, not globally */}

    <!-- Primary Meta -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <meta name="theme-color" content="#0A0A0A" />

    <!-- Open Graph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Ryan Xu | Visual Archive" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    {/* ── rel=me linking to the personal info hub (IndieAuth / Mastodon-style) ── */}
    {hubUrl && <link rel="me" href={hubUrl} />}

    {/* ── Structured data: Person + WebSite + page-specific blocks ── */}
    {allJsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    {/* Page-specific <head> injections (preconnects, stylesheets) */}
    <slot name="head" />

    <!-- Astro View Transitions — smooth page navigation -->
    <ClientRouter />
  </head>

  <body class:list={[
    "min-h-screen font-sans antialiased overflow-x-hidden",
    dark ? "bg-[#0A0A0A] text-[#FDFDFB]" : "bg-white text-gray-900"
  ]} style="cursor: none;">
    <!-- Custom cursor -->
    <div id="cursor-dot" aria-hidden="true"></div>
    <!-- Liquid ring: SVG ellipse that stretches with velocity -->
    <svg id="cursor-ring" aria-hidden="true"
      viewBox="0 0 40 40"
      xmlns="http://www.w3.org/2000/svg"
      style="position:fixed;top:0;left:0;width:40px;height:40px;pointer-events:none;z-index:9998;overflow:visible;mix-blend-mode:difference;opacity:0.55">
      <ellipse id="cursor-ellipse" cx="20" cy="20" rx="18" ry="18"
        fill="none" stroke="white" stroke-width="1"/>
    </svg>
    <slot />

    <!-- Global image protection: prevent right-click, drag, long-press save, and print -->
    <style is:global>
      img {
        -webkit-user-select: none;
        -moz-user-select: none;
        -ms-user-select: none;
        user-select: none;
        -webkit-touch-callout: none;
        pointer-events: auto;
        -webkit-user-drag: none;
        -khtml-user-drag: none;
        -moz-user-drag: none;
        -o-user-drag: none;
      }

      /* Mobile-only: prevent rubber-band bounce on the body so atmospheric
         fixed elements (video, sunbeam, grid) don't drift on iOS, and stop
         double-tap zoom which fights the cinematic transitions. */
      html, body {
        overscroll-behavior-y: none;
      }
      /* Touch devices don't get hover, so they shouldn't pay for cursor:none */
      @media (hover: none) {
        body { touch-action: manipulation; }
      }

      /* When printing, hide all images so a Save → Print → PDF route doesn't
         yield clean copies. Show a watermark in their place. */
      @media print {
        img, video, canvas, svg { display: none !important; }
        body::before {
          content: "© Ryan Xu · ryanxugallery.com — viewing copy, not for distribution.";
          display: block;
          padding: 2rem;
          font-family: ui-monospace, monospace;
          font-size: 12px;
          color: #444;
        }
      }

      /* ═══════════════════════════════════════════════════════
       *  Directional Page Transition — "Card Stack" model
       *  — Forward (click into a page): NEW page slides UP from below
       *    (pops up on top of the current card)
       *  — Back (leave / return):        OLD page slides DOWN off screen
       *    (the top card falls, revealing the card behind)
       *  Compositor-only transforms; no blur/box-shadow → smooth even
       *  while leaving heavy pages (e.g. /travel with Mapbox).
       * ═══════════════════════════════════════════════════════ */

      /* ─────────────────────────────────────────────────
       *  Forward nav (home → deep page):
       *    Handled by Astro View Transitions — new page slides up on top.
       *  Back nav (deep page → home / shallower):
       *    Handled by DIY JS below — current <body> translates DOWN off screen,
       *    then full-page navigation. This is the Framer-Motion
       *    `exit={{ y: "100%" }}` pattern, implemented with a CSS transform.
       *  ───────────────────────────────────────────────── */
      ::view-transition-old(root) {
        animation: vt-fade-out 0.45s cubic-bezier(0.4, 0, 0.2, 1) both;
        z-index: 1;
      }
      ::view-transition-new(root) {
        animation: vt-slide-up-in 0.55s cubic-bezier(0.22, 1, 0.36, 1) both;
        z-index: 2;
      }

      @keyframes vt-fade-out {
        from { opacity: 1; }
        to   { opacity: 0; }
      }
      @keyframes vt-slide-up-in {
        from { transform: translateY(100%); }
        to   { transform: translateY(0);    }
      }

      /* Back-nav slide-down: applied to <body> via JS. Uses compositor-only
         `transform` so it stays smooth even with heavy pages (Mapbox etc.). */
      body.vt-back-exit {
        transition: transform 0.55s cubic-bezier(0.22, 1, 0.36, 1);
        transform: translateY(100vh);
        will-change: transform;
      }

      /* Reduce motion: instant transition for accessibility */
      @media (prefers-reduced-motion: reduce) {
        ::view-transition-old(root),
        ::view-transition-new(root) {
          animation: none;
        }
      }
    </style>

    <style is:inline>
      /* Hide default cursor everywhere except lightbox */
      *, *::before, *::after { cursor: none !important; }
      /* Lightbox: restore default cursor (custom cursor is hidden via cursor-hidden class) */
      .cursor-hidden ~ * { cursor: default; }
      [style*="cursor: default"], [style*="cursor: default"] * { cursor: default !important; }

      #cursor-dot {
        position: fixed;
        top: 0; left: 0;
        width: 5px; height: 5px;
        margin: -2.5px 0 0 -2.5px;
        background: white;
        border-radius: 50%;
        pointer-events: none;
        z-index: 9999;
        will-change: left, top;
        mix-blend-mode: difference;
      }

      /* Ring is now an SVG — positioned and shaped via JS */
      #cursor-ring { will-change: left, top; }

      body.cursor-hidden #cursor-ring { opacity: 0 !important; }
      body.cursor-hidden #cursor-dot,
      body.cursor-hidden #cursor-ring { opacity: 0 !important; }

      @media (hover: none) {
        #cursor-dot, #cursor-ring { display: none !important; }
        *, *::before, *::after { cursor: auto !important; }
      }
    </style>

    <script is:inline>
      // ── Custom cursor (liquid deformation) ──
      (function() {
        var mouseX = -200, mouseY = -200;
        var ringX  = -200, ringY  = -200;
        var prevMouseX = -200, prevMouseY = -200;
        var velX = 0, velY = 0;
        var rxVal = 18, ryVal = 18, angleVal = 0;
        var raf = null;
        var initialized = false;
        var isClick = false;

        function lerp(a, b, t) { return a + (b - a) * t; }

        function init() {
          var dot  = document.getElementById('cursor-dot');
          var ring = document.getElementById('cursor-ring');
          var ellipse = document.getElementById('cursor-ellipse');
          if (!dot || !ring || !ellipse) return;

          if (raf) { cancelAnimationFrame(raf); raf = null; }
          document.body.classList.remove('cursor-hover', 'cursor-hidden');

          function loop() {
            // Smooth ring position
            ringX = lerp(ringX, mouseX, 0.13);
            ringY = lerp(ringY, mouseY, 0.13);

            // Velocity-based deformation
            velX = lerp(velX, mouseX - prevMouseX, 0.25);
            velY = lerp(velY, mouseY - prevMouseY, 0.25);
            prevMouseX = lerp(prevMouseX, mouseX, 0.25);
            prevMouseY = lerp(prevMouseY, mouseY, 0.25);

            var speed = Math.sqrt(velX * velX + velY * velY);

            // Stretch amount: faster = more elongated
            var stretch = Math.min(speed * 0.55, 10);
            var targetRx, targetRy, targetAngle;

            if (isClick) {
              targetRx = 11; targetRy = 11; targetAngle = 0;
            } else {
              targetRx = 18 + stretch;
              targetRy = Math.max(18 - stretch * 0.5, 9);
              // Angle follows velocity direction
              targetAngle = speed > 0.5 ? Math.atan2(velY, velX) * 180 / Math.PI : angleVal;
            }

            rxVal    = lerp(rxVal,    targetRx,    0.18);
            ryVal    = lerp(ryVal,    targetRy,    0.18);
            angleVal = lerp(angleVal, targetAngle, 0.14);

            // Position: center the SVG on cursor
            ring.style.left = (ringX - 20) + 'px';
            ring.style.top  = (ringY - 20) + 'px';

            // Apply deformation to ellipse
            ellipse.setAttribute('rx', rxVal.toFixed(2));
            ellipse.setAttribute('ry', ryVal.toFixed(2));
            ring.style.transformOrigin = '20px 20px';
            ring.style.transform = 'rotate(' + angleVal.toFixed(1) + 'deg)';

            // Opacity: normal 0.5, hover 0.3
            var targetOpacity = document.body.classList.contains('cursor-hover') ? '0.3' : '0.5';
            ring.style.opacity = targetOpacity;

            raf = requestAnimationFrame(loop);
          }
          loop();

          if (initialized) return;
          initialized = true;

          var hoverEls = 'a, button, [role="button"], .filmstrip-item, .work-photo-item, .cursor-pointer, input, textarea, select, label';

          document.addEventListener('mousemove', function(e) {
            mouseX = e.clientX;
            mouseY = e.clientY;
            var d = document.getElementById('cursor-dot');
            if (d) { d.style.left = mouseX + 'px'; d.style.top = mouseY + 'px'; }
            var isHover = !!(e.target && e.target.closest && e.target.closest(hoverEls));
            document.body.classList.toggle('cursor-hover', isHover);
          }, { passive: true });

          document.addEventListener('mousedown', function() {
            isClick = true;
            document.body.classList.add('cursor-click');
          });
          document.addEventListener('mouseup', function() {
            isClick = false;
            document.body.classList.remove('cursor-click');
          });
          document.addEventListener('mouseleave', function() { document.body.classList.add('cursor-hidden'); });
          document.addEventListener('mouseenter', function() { document.body.classList.remove('cursor-hidden'); });
        }

        init();
        document.addEventListener('astro:page-load', init);
      })();

      // ── Image protection ──
      // Block right-click anywhere on a photo (img tag OR a container that
      // declares itself as wrapping a protected image via .work-photo-item /
      // [data-protected] / nodes inside the lightbox).
      function isProtectedTarget(t) {
        if (!t || !t.closest) return false;
        if (t.tagName === 'IMG') return true;
        return !!t.closest('img, .work-photo-item, [data-protected], #lightbox, .photo-cell');
      }
      document.addEventListener('contextmenu', function(e) {
        if (isProtectedTarget(e.target)) e.preventDefault();
      }, true);
      document.addEventListener('dragstart', function(e) {
        if (isProtectedTarget(e.target)) e.preventDefault();
      }, true);
      // Block Cmd/Ctrl + S (save page) and Cmd/Ctrl + P (print).
      // Power users can still bypass via DevTools — this is a deterrent
      // for casual saving, not a security boundary.
      document.addEventListener('keydown', function(e) {
        var mod = e.metaKey || e.ctrlKey;
        if (mod && (e.key === 's' || e.key === 'S' || e.key === 'p' || e.key === 'P')) {
          e.preventDefault();
        }
      }, true);

      // ── Back-nav slide-down (DIY, Framer-Motion exit={{y:"100%"}} pattern) ──
      // Why DIY: browsers' CSS View Transitions API proved unreliable for the
      // "old-page slides down while new-page holds" pattern across Astro's
      // ClientRouter swap. Instead, we cancel the ClientRouter navigation for
      // back-direction clicks, animate <body> down with a CSS transform, and
      // then do a normal navigation to the destination. The page beneath the
      // sliding body is the browser background — set to match the destination
      // (dark for home, light for light pages) so no jarring flash appears.
      //
      // Back detection:
      //   1. Browser back/forward button (popstate)
      //   2. Link click where dest is "/" or has fewer path segments
      (function() {
        var DUR = 550; // ms — must match CSS `body.vt-back-exit` transition
        var EXITING = false;

        function depth(path) { return path.split('/').filter(Boolean).length; }

        function pathOf(u) {
          if (!u) return '';
          if (typeof u === 'string') {
            try { return new URL(u, window.location.origin).pathname; }
            catch (e) { return u; }
          }
          return u.pathname || '';
        }

        function isBackTo(toPath) {
          if (!toPath) return false;
          if (toPath === '/') return true;
          return depth(toPath) < depth(window.location.pathname);
        }

        // Pick background color that will be revealed under the sliding body.
        // All pages use dark theme (#0A0A0A).
        function bgFor(toPath) {
          return '#0A0A0A';
        }

        function runExit(href, bg) {
          if (EXITING) return;
          EXITING = true;
          // Paint the background the destination page will use, so the strip
          // exposed beneath the sliding body is the right color.
          document.documentElement.style.backgroundColor = bg;
          document.body.style.backgroundColor = getComputedStyle(document.body).backgroundColor || '';
          // Kick the animation on the next frame so the transition has a
          // clean starting state (transform:none → translateY(100vh))
          requestAnimationFrame(function() {
            document.body.classList.add('vt-back-exit');
          });
          setTimeout(function() {
            // Full navigation — simpler than splicing into ClientRouter
            window.location.href = href;
          }, DUR + 20);
        }

        // 1) Intercept "back"-direction link clicks BEFORE Astro's ClientRouter
        //    handler fires. Listener added on `document` in capture phase runs
        //    earlier than ClientRouter's delegated click handler.
        document.addEventListener('click', function(e) {
          if (EXITING) { e.preventDefault(); return; }
          if (e.defaultPrevented) return;
          if (e.button !== 0) return;                 // only primary click
          if (e.metaKey || e.ctrlKey || e.shiftKey || e.altKey) return;
          var a = e.target && e.target.closest ? e.target.closest('a[href]') : null;
          if (!a) return;
          if (a.target && a.target !== '' && a.target !== '_self') return;
          if (a.hasAttribute('download')) return;
          var href = a.getAttribute('href');
          if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
          var url;
          try { url = new URL(href, window.location.origin); } catch (err) { return; }
          if (url.origin !== window.location.origin) return;
          var toPath = url.pathname;
          if (toPath === window.location.pathname) return;
          if (!isBackTo(toPath)) return;

          e.preventDefault();
          e.stopPropagation();
          runExit(url.pathname + url.search + url.hash, bgFor(toPath));
        }, true); // capture phase — run before ClientRouter

        // 2) Intercept browser Back/Forward button. `popstate` fires after
        //    the URL has already changed, so we push the original URL back,
        //    run the exit animation, then navigate for real.
        var _lastPath = window.location.pathname;
        window.addEventListener('popstate', function() {
          var toPath = window.location.pathname;
          if (!isBackTo.call(null, toPath)) { _lastPath = toPath; return; }
          if (EXITING) return;
          var target = window.location.href;
          // Undo the popstate so the visible URL reflects the page we're still showing.
          // We use replaceState with the _lastPath so history length stays sane.
          history.pushState(null, '', _lastPath);
          runExit(target, bgFor(toPath));
        });
      })();

      // ── Filmstrip scroll restoration ──
      // Save scroll position when leaving homepage; restore when returning
      document.addEventListener('astro:before-preparation', function(e) {
        if (window.location.pathname === '/') {
          sessionStorage.setItem('home-filmstrip-scroll', String(window.scrollY));
        }
      });
      document.addEventListener('astro:page-load', function() {
        if (window.location.pathname === '/') {
          var saved = sessionStorage.getItem('home-filmstrip-scroll');
          if (saved) {
            sessionStorage.removeItem('home-filmstrip-scroll');
            var y = parseInt(saved, 10);
            // Only restore if user was past the hero (i.e., in the filmstrip area)
            if (y > 100) {
              // Delay to allow React hydration before scrolling
              setTimeout(function() {
                window.scrollTo({ top: y, behavior: 'instant' });
              }, 120);
            }
          }
        }
      });
    </script>
  </body>
</html>
