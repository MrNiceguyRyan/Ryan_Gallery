---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav';
import Footer from '../components/Footer.astro';
import ParallaxHero from '../components/ParallaxHero';
import { sanityClient } from 'sanity:client';

const currentPath = Astro.url.pathname;

const settings = await sanityClient.fetch(`
  *[_type == "siteSettings"][0] {
    email,
    instagram
  }
`);

const email     = settings?.email     ?? 'hello@ryanxu.com';
const instagram = settings?.instagram ?? 'https://instagram.com';

// Derive a clean display handle from the URL, e.g. "https://instagram.com/ryan.xu" → "@ryan.xu"
const instagramHandle = (() => {
  try {
    const path = new URL(instagram).pathname.replace(/\/$/, '');
    const handle = path.split('/').filter(Boolean).pop();
    return handle ? `@${handle}` : '@instagram';
  } catch {
    return '@instagram';
  }
})();
---

<Layout title="Contact | Ryan" description="Get in touch for collaborations and creative projects.">
  <Nav client:load currentPath={currentPath} />

  <!-- Parallax Hero -->
  <ParallaxHero
    client:load
    imageUrl="https://cdn.sanity.io/images/z610fooo/production/e69f9258142218c5cd649a9c01d4fe89d0335563-6048x4032.jpg?auto=format&w=1800&q=85"
    title="Let's"
    titleLine2="Connect."
    label="Open for collaboration"
    meta={['New York, NY', 'Worldwide']}
    objectPosition="center 30%"
  />

  <section class="py-24 px-6 md:px-16 max-w-4xl mx-auto">
    <!-- Contact grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <!-- Email -->
      <a
        href={`mailto:${email}`}
        class="group p-8 rounded-2xl bg-gray-50 hover:bg-gray-100 transition-colors duration-300 flex flex-col"
      >
        <svg class="w-6 h-6 text-gray-300 mb-5 group-hover:text-gray-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75" />
        </svg>
        <h3 class="text-lg font-light text-gray-900 tracking-tight">Email</h3>
        <p class="text-sm text-gray-400 mt-1 font-light">{email}</p>
        <div class="mt-auto pt-6">
          <span class="text-xs text-gray-300 group-hover:text-gray-400 transition-colors font-light tracking-wider uppercase">
            Send message →
          </span>
        </div>
      </a>

      <!-- Instagram -->
      <a
        href={instagram}
        target="_blank"
        rel="noopener noreferrer"
        class="group p-8 rounded-2xl bg-gray-50 hover:bg-gray-100 transition-colors duration-300 flex flex-col"
      >
        <svg class="w-6 h-6 text-gray-300 mb-5 group-hover:text-gray-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.827 6.175A2.31 2.31 0 015.186 7.23c-.38.054-.757.112-1.134.175C2.999 7.58 2.25 8.507 2.25 9.574V18a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9.574c0-1.067-.75-1.994-1.802-2.169a47.865 47.865 0 00-1.134-.175 2.31 2.31 0 01-1.64-1.055l-.822-1.316a2.192 2.192 0 00-1.736-1.039 48.774 48.774 0 00-5.232 0 2.192 2.192 0 00-1.736 1.039l-.821 1.316z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M16.5 12.75a4.5 4.5 0 11-9 0 4.5 4.5 0 019 0zM18.75 10.5h.008v.008h-.008V10.5z" />
        </svg>
        <h3 class="text-lg font-light text-gray-900 tracking-tight">Instagram</h3>
        <p class="text-sm text-gray-400 mt-1 font-light">{instagramHandle}</p>
        <div class="mt-auto pt-6">
          <span class="text-xs text-gray-300 group-hover:text-gray-400 transition-colors font-light tracking-wider uppercase">
            Follow →
          </span>
        </div>
      </a>

      <!-- Location -->
      <div class="p-8 rounded-2xl bg-gray-50 flex flex-col">
        <svg class="w-6 h-6 text-gray-300 mb-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" />
        </svg>
        <h3 class="text-lg font-light text-gray-900 tracking-tight">Based in</h3>
        <p class="text-sm text-gray-400 mt-1 font-light">New York / Worldwide</p>
        <div class="mt-auto pt-6">
          <span class="text-xs text-gray-300 font-light tracking-wider uppercase">
            Available for travel
          </span>
        </div>
      </div>

      <!-- Availability -->
      <div class="p-8 rounded-2xl bg-gray-50 flex flex-col">
        <svg class="w-6 h-6 text-gray-300 mb-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.455 2.456L21.75 6l-1.036.259a3.375 3.375 0 00-2.455 2.456zM16.894 20.567L16.5 21.75l-.394-1.183a2.25 2.25 0 00-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 001.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 001.423 1.423l1.183.394-1.183.394a2.25 2.25 0 00-1.423 1.423z" />
        </svg>
        <h3 class="text-lg font-light text-gray-900 tracking-tight">Availability</h3>
        <p class="text-sm text-gray-400 mt-1 font-light">Open for freelance & collaborations</p>
        <div class="mt-auto pt-6">
          <span class="text-xs text-gray-300 font-light tracking-wider uppercase">
            Currently booking 2026
          </span>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="mt-20 pt-16 border-t border-gray-100 text-center">
      <p class="text-gray-400 text-sm font-light leading-relaxed max-w-md mx-auto">
        Whether it's a commercial project, editorial work, or simply a
        conversation about photography — I'd love to hear from you.
      </p>
      <a
        href={`mailto:${email}`}
        class="inline-block mt-8 px-8 py-3 bg-gray-900 text-white text-sm font-light tracking-wider rounded-full hover:bg-gray-800 transition-colors duration-300"
      >
        Get in Touch
      </a>
    </div>
  </section>

  <Footer />
</Layout>
