---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav';
import Footer from '../components/Footer.astro';
import { sanityClient } from 'sanity:client';
import type { Photo } from '../types';
import MapboxMap from '../components/MapboxMap';
import { getMapboxToken } from '../config/mapbox';

const currentPath = Astro.url.pathname;

const photos: Photo[] = await sanityClient.fetch(`
  *[_type == "photo" && defined(location)] | order(_createdAt desc) {
    _id,
    title,
    "imageUrl": image.asset->url,
    camera,
    focalLength,
    aperture,
    shutterSpeed,
    iso,
    styleCategory,
    location,
    collection->{
      name,
      "slug": slug.current
    }
  }
`);

const mapboxToken = getMapboxToken();

// ── Live atlas stats (derived from the same fetch, no extra query) ──
const frames = photos.length;
const locations = new Set(
  photos
    .filter((p) => p.location?.lat != null && p.location?.lng != null)
    .map((p) => `${p.location!.lat.toFixed(2)},${p.location!.lng.toFixed(2)}`)
).size;
const collections = new Set(
  photos.map((p) => p.collection?.name).filter(Boolean)
).size;

const stats = [
  { value: String(locations).padStart(2, '0'), label: 'Locations' },
  { value: String(frames).padStart(2, '0'), label: 'Frames' },
  { value: String(collections).padStart(2, '0'), label: 'Collections' },
  { value: 'US', label: 'Coverage' },
];

// City names for the kinetic marquee (artistic typographic band).
const cityNames = [
  ...new Set(
    photos.map((p) => p.location?.city).filter((c): c is string => !!c)
  ),
];
---

<Layout title="Map | Ryan" description="Geo-tagged photographic archive. Every frame placed on the map across the United States." dark={true} ogImage={photos[0]?.imageUrl ? `${photos[0].imageUrl}?auto=format&w=1200&q=85` : undefined}>
  {/* Mapbox-only head injections — these were moved off the global Layout so
       /, /about, /works/[slug] no longer pay for them. */}
  <Fragment slot="head">
    <link rel="preconnect" href="https://api.mapbox.com" crossorigin />
    <link rel="preconnect" href="https://events.mapbox.com" crossorigin />
    <link rel="stylesheet" href="https://api.mapbox.com/mapbox-gl-js/v3.20.0/mapbox-gl.css" />
  </Fragment>

  <Nav client:load currentPath={currentPath} dark={true} />

  <!-- ── Hero — pure-typographic kinetic "light band" over dark ── -->
  <section class="relative h-[78vh] md:h-[86vh] overflow-hidden bg-[#0A0A0A]">
    <!-- Atmospheric warm glow (fills the dark, echoes the LED dots) -->
    <div
      class="absolute inset-0 z-0 hero-glow"
      style="background: radial-gradient(58vmax 46vmax at 50% 44%, rgba(255,200,130,0.07), transparent 70%);"
    ></div>
    <!-- Faint coordinate hairlines for atlas texture -->
    <div class="absolute inset-0 z-0 opacity-[0.04] hidden md:block" style="background-image: linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px); background-size: 120px 120px;"></div>

    <!-- Background light band: two opposing rows of outlined place names -->
    {cityNames.length > 0 && (
      <div class="absolute inset-0 z-[1] flex flex-col justify-center gap-2 md:gap-4 pointer-events-none select-none">
        <div class="atlas-marquee">
          <div class="atlas-marquee-track atlas-row-a flex whitespace-nowrap will-change-transform">
            {[0, 1].map(() => (
              <div class="flex items-center shrink-0" aria-hidden="true">
                {cityNames.map((city) => (
                  <span class="flex items-center">
                    <span class="band-name px-5 md:px-8 text-6xl md:text-8xl font-serif italic tracking-tight">{city}</span>
                    <span class="band-dot">&bull;</span>
                  </span>
                ))}
              </div>
            ))}
          </div>
        </div>
        <div class="atlas-marquee">
          <div class="atlas-marquee-track atlas-row-b flex whitespace-nowrap will-change-transform">
            {[0, 1].map(() => (
              <div class="flex items-center shrink-0" aria-hidden="true">
                {cityNames.map((city) => (
                  <span class="flex items-center">
                    <span class="band-name px-5 md:px-8 text-6xl md:text-8xl font-serif italic tracking-tight">{city}</span>
                    <span class="band-dot">&bull;</span>
                  </span>
                ))}
              </div>
            ))}
          </div>
        </div>
      </div>
    )}

    <!-- Title-legibility wash: solid dark anchored bottom-left, fading up/right
         so the band stays visible elsewhere; plus a soft top/bottom vignette. -->
    <div class="absolute inset-0 z-[2] bg-gradient-to-tr from-[#0A0A0A] via-[#0A0A0A]/65 to-transparent"></div>
    <div class="absolute inset-0 z-[2] bg-gradient-to-t from-[#0A0A0A] via-transparent to-[#0A0A0A]/55"></div>

    <!-- Foreground content -->
    <div class="absolute bottom-12 md:bottom-20 left-5 right-5 md:left-16 md:right-auto z-[3] max-w-2xl animate-fade-in-up">
      <p class="font-mono text-[10px] md:text-xs tracking-[0.5em] uppercase text-white/45 mb-4">
        // the territory
      </p>
      <h1 class="text-5xl md:text-7xl lg:text-8xl font-serif italic tracking-tight leading-[0.9] text-[#FDFDFB]">
        Mapping the<br />Archive.
      </h1>
      <div class="flex items-center gap-4 md:gap-5 mt-6 flex-wrap font-mono text-[11px] md:text-xs text-white/45 tracking-wider">
        <span>{locations} Locations</span>
        <span class="w-5 h-px bg-white/25"></span>
        <span>{frames} Frames</span>
        <span class="w-5 h-px bg-white/25"></span>
        <span>United States</span>
      </div>
    </div>

    <!-- Scroll indicator -->
    <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-[3]">
      <div class="hero-scroll w-px h-7 bg-white/30 origin-top"></div>
    </div>
  </section>

  <!-- ── Atlas intro + live stats masthead ── -->
  <section class="max-w-7xl mx-auto px-6 md:px-16 pt-20 md:pt-28 animate-fade-in-up">
    <div class="grid lg:grid-cols-12 gap-8 lg:gap-16 items-end border-b border-white/10 pb-12 md:pb-16">
      <div class="lg:col-span-7">
        <span class="block font-mono text-[10px] tracking-[0.5em] uppercase text-white/35 mb-6">
          // the territory
        </span>
        <h2 class="text-4xl md:text-6xl lg:text-7xl font-serif italic tracking-tighter leading-[0.92] text-[#FDFDFB]">
          Every frame,<br />placed on the map.
        </h2>
      </div>
      <div class="lg:col-span-5 lg:pb-3">
        <p class="text-[15px] md:text-base leading-[1.8] text-white/55 font-light max-w-md">
          A geographic index of the archive — each pin marks where a frame
          was made. Drag, zoom, and trace the route across the United States;
          select a city to open its coordinates.
        </p>
      </div>
    </div>

    <!-- Stats row -->
    <div class="grid grid-cols-2 md:grid-cols-4 gap-y-10 gap-x-6 pt-12 md:pt-16">
      {stats.map((s, i) => {
        const numeric = /^\d+$/.test(s.value);
        return (
          <div class={`flex flex-col gap-2 ${i > 0 ? 'md:border-l md:border-white/10 md:pl-8' : ''}`}>
            <span
              class="text-4xl md:text-5xl lg:text-6xl font-serif italic tracking-tight text-[#FDFDFB] leading-none tabular-nums"
              data-countup={numeric ? s.value : undefined}
            >
              {s.value}
            </span>
            <span class="font-mono text-[9px] tracking-[0.4em] uppercase text-white/35">
              {s.label}
            </span>
          </div>
        );
      })}
    </div>
  </section>

  <!-- ── Interactive Atlas — near-fullscreen map, location list on the right ── -->
  <section
    id="atlas-map"
    class="max-w-[1800px] mx-auto px-4 md:px-6 pt-10 md:pt-14 pb-12"
    style="scroll-margin-top: 5rem;"
  >
    <div class="flex items-end justify-between mb-4 md:mb-5 px-1">
      <div class="flex items-center gap-3">
        <span class="w-1.5 h-1.5 rounded-full bg-white/50"></span>
        <span class="font-mono text-[10px] tracking-[0.4em] uppercase text-white/45">
          Interactive Atlas
        </span>
      </div>
      <span class="hidden md:block font-mono text-[9px] tracking-[0.3em] uppercase text-white/25">
        Drag · Scroll to zoom · Pick a city →
      </span>
    </div>

    {/* client:visible — Mapbox hydrates on scroll. showLocationList=true puts
         the region/city list on the RIGHT of the near-fullscreen map. */}
    <MapboxMap client:visible photos={photos} mapboxToken={mapboxToken} showLocationList={true} />

    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-2 mt-4 px-1 font-mono text-[9px] tracking-[0.3em] uppercase text-white/25">
      <span>Coordinates sourced from frame EXIF</span>
      <span>{frames} geotagged frames · {locations} locations</span>
    </div>
  </section>

  {/* End-of-mapped-frames terminator — matches the homepage's "End of archive"
       and the about page's markers. Same visual signature across pages. */}
  <div class="pt-10 pb-4 flex flex-col items-center gap-3 opacity-30">
    <div class="w-px h-10 bg-white/40"></div>
    <span class="text-[9px] uppercase tracking-[0.5em] font-mono">
      End of mapped frames
    </span>
    <span class="text-[8px] font-mono opacity-60">
      // {locations} coordinates
    </span>
  </div>

  <Footer dark={true} />
</Layout>

<style>
  /* ── Kinetic place-name "light band" (hero background) ──
     Two opposing rows of outlined serif type with glowing LED-like dots,
     each row edge-faded to read as a band of light. Seamless loop (each
     track holds two identical copies → translateX(-50%) repeats). */
  .atlas-marquee {
    overflow: hidden;
    -webkit-mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
            mask-image: linear-gradient(90deg, transparent, #000 7%, #000 93%, transparent);
  }
  .atlas-marquee-track {
    animation: atlas-marquee 22s linear infinite;
  }
  .atlas-row-b {
    animation-duration: 30s;
    animation-direction: reverse;
  }
  @keyframes atlas-marquee {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }

  /* Outlined "light" type — slightly brighter now that it's the hero's
     primary visual (no photo behind it). */
  .band-name {
    color: transparent;
    -webkit-text-stroke: 1px rgba(255, 255, 255, 0.30);
    text-shadow: 0 0 30px rgba(255, 255, 255, 0.06);
  }
  /* Glowing amber LED dot between names */
  .band-dot {
    padding: 0 0.15em;
    font-size: 0.5em;
    color: rgba(255, 200, 130, 0.75);
    text-shadow: 0 0 12px rgba(255, 200, 130, 0.65), 0 0 4px rgba(255, 200, 130, 0.85);
    transform: translateY(-0.35em);
    display: inline-block;
  }

  /* Hero atmosphere glow breath + scroll indicator */
  .hero-glow { animation: hero-glow 9s ease-in-out infinite; }
  @keyframes hero-glow { 0%, 100% { opacity: 0.8; } 50% { opacity: 1; } }
  .hero-scroll { animation: hero-scroll 1.8s ease-in-out infinite; }
  @keyframes hero-scroll { 0%, 100% { transform: scaleY(0); } 50% { transform: scaleY(1); } }

  @media (prefers-reduced-motion: reduce) {
    .atlas-marquee-track,
    .hero-glow,
    .hero-scroll { animation: none; }
  }
</style>

<script>
  // Count-up the atlas stats when they scroll into view.
  function runAtlasCountUps() {
    const els = document.querySelectorAll<HTMLElement>('[data-countup]');
    if (!els.length) return;
    const io = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;
        io.unobserve(el);
        const raw = el.getAttribute('data-countup') || '';
        const target = parseInt(raw, 10);
        const pad = raw.length;
        if (isNaN(target)) return;
        const dur = 1100;
        const start = performance.now();
        const tick = (now: number) => {
          const t = Math.min((now - start) / dur, 1);
          const eased = 1 - Math.pow(1 - t, 3);
          el.textContent = String(Math.round(eased * target)).padStart(pad, '0');
          if (t < 1) requestAnimationFrame(tick);
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.5 });
    els.forEach((el) => io.observe(el));
  }
  document.addEventListener('astro:page-load', runAtlasCountUps);
</script>
