---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav';
import { sanityClient } from 'sanity:client';
import type { Photo } from '../types';
import MapboxMap from '../components/MapboxMap';
import { getMapboxToken } from '../config/mapbox';

const currentPath = Astro.url.pathname;

const photos: Photo[] = await sanityClient.fetch(`
  *[_type == "photo" && defined(location)] | order(_createdAt desc) {
    _id,
    title,
    "imageUrl": image.asset->url,
    camera,
    focalLength,
    aperture,
    shutterSpeed,
    iso,
    styleCategory,
    location,
    collection->{
      name,
      "slug": slug.current
    }
  }
`);

const mapboxToken = getMapboxToken();
---

<Layout title="Travel | Ryan" description="The Interactive Geo-Map — photography locations around the world.">
  <Nav client:load currentPath={currentPath} />

  <section class="pt-28 pb-24 px-6 md:px-16 max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-5xl md:text-7xl font-extralight tracking-tighter text-gray-900 leading-[0.95]">
        The Interactive<br />Geo-Map.
      </h1>
      <p class="text-gray-400 text-lg font-light mt-6 max-w-lg leading-relaxed">
        Every photograph lives somewhere. Explore the coordinates behind the collection.
      </p>
      <div class="flex items-center gap-4 mt-4 text-[10px] font-mono text-gray-300">
        <span>{photos.length} photographs</span>
        <span>·</span>
        <span>Mapped locations</span>
      </div>
    </div>

    <!-- Map -->
    <MapboxMap client:load photos={photos} mapboxToken={mapboxToken} />

    <!-- Location list -->
    <div class="mt-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
      {[...new Map(photos.filter(p => p.location?.city).map(p => [p.location!.city!, p])).values()].map((photo) => (
        <div class="group p-6 rounded-2xl bg-gray-50 hover:bg-gray-100 transition-colors duration-300">
          <div class="flex items-start gap-4">
            <div class="w-16 h-16 rounded-xl overflow-hidden flex-shrink-0">
              <img
                src={`${photo.imageUrl}?auto=format&w=200&q=75`}
                alt={photo.location?.city}
                class="w-full h-full object-cover"
              />
            </div>
            <div>
              <h3 class="text-base font-light text-gray-900 tracking-tight">{photo.location?.city}</h3>
              <p class="text-xs text-gray-400 mt-0.5 font-light">{photo.location?.country}</p>
              <p class="text-[10px] font-mono text-gray-300 mt-1">
                {Math.abs(photo.location?.lat ?? 0).toFixed(4)}°{(photo.location?.lat ?? 0) >= 0 ? 'N' : 'S'}, {Math.abs(photo.location?.lng ?? 0).toFixed(4)}°{(photo.location?.lng ?? 0) >= 0 ? 'E' : 'W'}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-20 px-6 md:px-16 max-w-7xl mx-auto border-t border-gray-100 mt-12">
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
      <div>
        <h2 class="text-lg font-light text-gray-900 tracking-tight">Visual Archive.</h2>
        <p class="text-xs text-gray-400 mt-1 font-light">
          &copy; {new Date().getFullYear()} Ryan. All rights reserved.
        </p>
      </div>
      <div class="flex items-center gap-6 text-xs text-gray-400 font-mono">
        <span>Nikon Zf</span>
        <span class="text-gray-200">|</span>
        <span>Astro + React</span>
        <span class="text-gray-200">|</span>
        <span>Sanity CMS</span>
      </div>
    </div>
  </footer>
</Layout>
