---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav';
import Footer from '../components/Footer.astro';
import { sanityClient } from 'sanity:client';
import type { Photo } from '../types';
import MapboxMap from '../components/MapboxMap';
import ParallaxHero from '../components/ParallaxHero';
import { getMapboxToken } from '../config/mapbox';

const currentPath = Astro.url.pathname;

const photos: Photo[] = await sanityClient.fetch(`
  *[_type == "photo" && defined(location)] | order(_createdAt desc) {
    _id,
    title,
    "imageUrl": image.asset->url,
    camera,
    focalLength,
    aperture,
    shutterSpeed,
    iso,
    styleCategory,
    location,
    collection->{
      name,
      "slug": slug.current
    }
  }
`);

const mapboxToken = getMapboxToken();
---

<Layout title="Travel | Ryan" description="The Interactive Geo-Map — photography locations around the world.">
  <Nav client:load currentPath={currentPath} />

  <!-- Parallax Hero -->
  <ParallaxHero
    client:load
    imageUrl="https://cdn.sanity.io/images/z610fooo/production/f48098bfe8a7bfa3d148b936b8031f61fa4e78bc-7728x5152.jpg?auto=format&w=1800&q=85"
    title="The Interactive"
    titleLine2="Geo-Map."
    label="Explore the coordinates"
    meta={[`${photos.length} Locations`, 'Mapped worldwide']}
    objectPosition="center 60%"
  />

  <section class="py-16 px-6 md:px-16 max-w-7xl mx-auto animate-fade-in-up">
    <!-- Map + integrated location cards -->
    <MapboxMap client:load photos={photos} mapboxToken={mapboxToken} showLocationList={true} />
  </section>

  <Footer />
</Layout>
