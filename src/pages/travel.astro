---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from 'sanity:client';
import type { Photo } from '../types';
import MapboxMap from '../components/MapboxMap';

const mapboxToken = import.meta.env.PUBLIC_MAPBOX_TOKEN;

// ─── GROQ: Photos with geo-coordinates ───
const photos: Photo[] = await sanityClient.fetch(`
  *[_type == "photo" && defined(location.lat) && defined(location.lng)] | order(_createdAt desc) {
    _id,
    title,
    "imageUrl": image.asset->url,
    camera,
    focalLength,
    aperture,
    shutterSpeed,
    iso,
    styleCategory,
    location,
    collection->{
      name,
      "slug": slug.current
    }
  }
`);

// Derive unique locations
const uniqueCities = [...new Set(photos.map((p) => p.location?.city).filter(Boolean))];
const uniqueCountries = [...new Set(photos.map((p) => p.location?.country).filter(Boolean))];
---

<Layout title="Travel | Ryan" description="An interactive geo-map of photographic memories across the globe.">
  <section class="pt-20 pb-24 px-6 md:px-16 max-w-7xl mx-auto">
    <!-- Header -->
    <div class="mb-12">
      <h1 class="text-5xl md:text-7xl font-extralight tracking-tighter text-gray-900 leading-[0.95]">
        The Interactive<br />Geo-Map.
      </h1>
      <p class="text-gray-400 text-lg font-light mt-6 max-w-lg leading-relaxed">
        Every coordinate holds a story. Explore the world through my lens.
      </p>
    </div>

    <!-- Map -->
    {photos.length > 0 && mapboxToken ? (
      <MapboxMap client:load photos={photos} mapboxToken={mapboxToken} />
    ) : (
      <div class="h-[500px] rounded-2xl bg-gray-50 flex items-center justify-center">
        <p class="text-gray-400 font-light">No geo-tagged photos yet.</p>
      </div>
    )}

    <!-- Stats -->
    <div class="mt-12 flex flex-wrap gap-8 pt-8 border-t border-gray-100">
      <div>
        <span class="text-2xl font-extralight text-gray-900 tabular-nums">{uniqueCities.length}</span>
        <p class="text-[10px] text-gray-400 uppercase tracking-[0.15em] mt-0.5">Cities</p>
      </div>
      <div>
        <span class="text-2xl font-extralight text-gray-900 tabular-nums">{uniqueCountries.length}</span>
        <p class="text-[10px] text-gray-400 uppercase tracking-[0.15em] mt-0.5">Countries</p>
      </div>
      <div>
        <span class="text-2xl font-extralight text-gray-900 tabular-nums">{photos.length}</span>
        <p class="text-[10px] text-gray-400 uppercase tracking-[0.15em] mt-0.5">Photographs</p>
      </div>
    </div>
  </section>
</Layout>
