---
import Layout from '../../layouts/Layout.astro';
import { sanityClient } from 'sanity:client';
import type { Collection, Photo } from '../../types';
import WorkStory from '../../components/works/WorkStory';

export async function getStaticPaths() {
  const collections = await sanityClient.fetch(`
    *[_type == "collection" && defined(slug.current)] {
      "slug": slug.current
    }
  `);

  return collections.map((c: { slug: string }) => ({
    params: { slug: c.slug },
  }));
}

const { slug } = Astro.params;

// Fetch ALL collections (with embedded photos) exactly as the homepage does,
// so the story experience — and "Keep Reading" order — matches the homepage
// overlay. The visited collection is found within this list by slug.
const collections: Collection[] = await sanityClient.fetch(`
  *[_type == "collection"] | order(year desc) {
    _id,
    name,
    "slug": slug.current,
    subtitle,
    "coverImageUrl": coverImage.asset->url,
    "palette": coverImage.asset->metadata.palette,
    location,
    year,
    description,
    introduction,
    gridSize,
    "photos": *[_type == "photo" && references(^._id)] | order(_createdAt desc) {
      _id,
      title,
      "imageUrl": image.asset->url,
      "width": image.asset->metadata.dimensions.width,
      "height": image.asset->metadata.dimensions.height,
      camera,
      focalLength,
      aperture,
      shutterSpeed,
      iso,
      styleCategory,
      location
    }
  }
`);

// Collections that actually have photos drive "Keep Reading" (mirrors the
// homepage's activeCollections).
const activeCollections = collections.filter((c) => (c.photos?.length || 0) > 0);
const collection = collections.find((c) => c.slug === slug) ?? collections[0];
const photos: Photo[] = collection.photos ?? [];

// ─── Build per-page SEO values ───
const pageTitle = collection.year
  ? `${collection.name} ${collection.year} | Ryan`
  : `${collection.name} | Ryan`;

const pageDescription = (() => {
  if (collection.description) return collection.description;
  if (collection.subtitle) return collection.subtitle;
  const parts: string[] = [];
  if (collection.location) parts.push(collection.location);
  if (collection.year) parts.push(String(collection.year));
  const suffix = `${photos.length} photograph${photos.length === 1 ? '' : 's'} by Ryan Xu.`;
  return parts.length > 0
    ? `${parts.join(' · ')} — ${suffix}`
    : suffix;
})();

// Use cover image for OG; fall back to first photo; fall back to default
const ogImage =
  (collection.coverImageUrl
    ? `${collection.coverImageUrl}?auto=format&w=1200&q=85`
    : null) ??
  (photos[0]?.imageUrl
    ? `${photos[0].imageUrl}?auto=format&w=1200&q=85`
    : null) ??
  undefined;

// ─── JSON-LD: ImageGallery + ImageObject[] ───
const siteUrl = (Astro.site ?? new URL('https://ryanxugallery.com')).toString().replace(/\/$/, '');
const pageUrl = `${siteUrl}/works/${collection.slug}`;

const imageObjects = photos.slice(0, 12).map((p) => ({
  '@type': 'ImageObject',
  contentUrl: `${p.imageUrl}?auto=format&w=1600&q=85`,
  thumbnailUrl: `${p.imageUrl}?auto=format&w=400&q=70`,
  name: p.title || `${collection.name} — photograph`,
  width: p.width ?? undefined,
  height: p.height ?? undefined,
  author: { '@type': 'Person', name: 'Ryan Xu' },
  copyrightHolder: { '@type': 'Person', name: 'Ryan Xu' },
  ...(p.camera ? { camera: p.camera } : {}),
}));

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: collection.name,
  description: pageDescription,
  url: pageUrl,
  ...(collection.year ? { datePublished: String(collection.year) } : {}),
  ...(collection.location ? { contentLocation: { '@type': 'Place', name: collection.location } } : {}),
  author: { '@type': 'Person', name: 'Ryan Xu' },
  image: imageObjects,
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogImage={ogImage}
  ogType="article"
  dark={true}
  jsonLd={collectionSchema}
>
  {/* Same MagazineLayout story used by the homepage overlay — so arriving
       from the Map's "Explore Story" link is identical to opening a story
       on the homepage. */}
  <WorkStory client:load collection={collection} allCollections={activeCollections} />
</Layout>
