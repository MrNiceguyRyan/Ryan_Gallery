---
import Layout from '../../layouts/Layout.astro';
import { sanityClient } from 'sanity:client';
import type { Collection, Photo } from '../../types';
import WorkDetailPage from '../../components/works/WorkDetailPage';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const collections = await sanityClient.fetch(`
    *[_type == "collection" && defined(slug.current)] {
      "slug": slug.current
    }
  `);

  return collections.map((c: { slug: string }) => ({
    params: { slug: c.slug },
  }));
}

const { slug } = Astro.params;

const collection: Collection = await sanityClient.fetch(
  `*[_type == "collection" && slug.current == $slug][0] {
    _id,
    name,
    "slug": slug.current,
    subtitle,
    "coverImageUrl": coverImage.asset->url,
    location,
    year,
    description,
    introduction,
    gridSize
  }`,
  { slug },
);

const photos: Photo[] = await sanityClient.fetch(
  `*[_type == "photo" && references($collectionId)] | order(_createdAt asc) {
    _id,
    title,
    "imageUrl": image.asset->url,
    "width": image.asset->metadata.dimensions.width,
    "height": image.asset->metadata.dimensions.height,
    camera,
    focalLength,
    aperture,
    shutterSpeed,
    iso,
    styleCategory,
    location
  }`,
  { collectionId: collection._id },
);

// ─── Build per-page SEO values ───
const pageTitle = collection.year
  ? `${collection.name} ${collection.year} | Ryan`
  : `${collection.name} | Ryan`;

const pageDescription = (() => {
  if (collection.description) return collection.description;
  if (collection.subtitle) return collection.subtitle;
  const parts: string[] = [];
  if (collection.location) parts.push(collection.location);
  if (collection.year) parts.push(String(collection.year));
  const suffix = `${photos.length} photograph${photos.length === 1 ? '' : 's'} by Ryan Xu.`;
  return parts.length > 0
    ? `${parts.join(' · ')} — ${suffix}`
    : suffix;
})();

// Use cover image for OG; fall back to first photo; fall back to default
const ogImage =
  (collection.coverImageUrl
    ? `${collection.coverImageUrl}?auto=format&w=1200&q=85`
    : null) ??
  (photos[0]?.imageUrl
    ? `${photos[0].imageUrl}?auto=format&w=1200&q=85`
    : null) ??
  undefined;

// ─── JSON-LD: ImageGallery + ImageObject[] ───
const siteUrl = (Astro.site ?? new URL('https://ryangallery.com')).toString().replace(/\/$/, '');
const pageUrl = `${siteUrl}/works/${collection.slug}`;

const imageObjects = photos.slice(0, 12).map((p) => ({
  '@type': 'ImageObject',
  contentUrl: `${p.imageUrl}?auto=format&w=1600&q=85`,
  thumbnailUrl: `${p.imageUrl}?auto=format&w=400&q=70`,
  name: p.title || `${collection.name} — photograph`,
  width: p.width ?? undefined,
  height: p.height ?? undefined,
  author: { '@type': 'Person', name: 'Ryan Xu' },
  copyrightHolder: { '@type': 'Person', name: 'Ryan Xu' },
  ...(p.camera ? { camera: p.camera } : {}),
}));

const collectionSchema = {
  '@context': 'https://schema.org',
  '@type': 'ImageGallery',
  name: collection.name,
  description: pageDescription,
  url: pageUrl,
  ...(collection.year ? { datePublished: String(collection.year) } : {}),
  ...(collection.location ? { contentLocation: { '@type': 'Place', name: collection.location } } : {}),
  author: { '@type': 'Person', name: 'Ryan Xu' },
  image: imageObjects,
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  ogImage={ogImage}
  ogType="article"
  jsonLd={collectionSchema}
>
  <WorkDetailPage client:load collection={collection} photos={photos} />
  <Footer />
</Layout>
