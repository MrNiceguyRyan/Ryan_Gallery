---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from 'sanity:client';
import type { Collection, Photo } from '../types';
import HomePage from '../components/home/HomePage';

// ─── GROQ: All collections with photos + location data ───
const collections: Collection[] = await sanityClient.fetch(`
  *[_type == "collection"] | order(year desc) {
    _id,
    name,
    "slug": slug.current,
    subtitle,
    "coverImageUrl": coverImage.asset->url,
    location,
    year,
    description,
    gridSize,
    "photoCount": count(*[_type == "photo" && references(^._id)]),
    "photos": *[_type == "photo" && references(^._id)] | order(_createdAt desc) {
      _id,
      title,
      "imageUrl": image.asset->url,
      camera,
      focalLength,
      aperture,
      shutterSpeed,
      iso,
      styleCategory,
      location
    }
  }
`);

// ─── GROQ: All photos ───
const photos: Photo[] = await sanityClient.fetch(`
  *[_type == "photo"] | order(_createdAt desc) {
    _id,
    title,
    "imageUrl": image.asset->url,
    camera,
    focalLength,
    aperture,
    shutterSpeed,
    iso,
    styleCategory,
    location,
    collection->{
      name,
      "slug": slug.current
    }
  }
`);
---

<Layout>
  <HomePage client:load collections={collections} photos={photos} />
</Layout>
