---
import Layout from '../layouts/Layout.astro';
import { sanityClient } from 'sanity:client';
import type { Collection } from '../types';
import HomePage from '../components/home/HomePage';

// ─── GROQ: All collections with photos + location data ───
const collections: Collection[] = await sanityClient.fetch(`
  *[_type == "collection"] | order(year desc) {
    _id,
    name,
    "slug": slug.current,
    subtitle,
    "coverImageUrl": coverImage.asset->url,
    "palette": coverImage.asset->metadata.palette,
    location,
    region,
    year,
    description,
    introduction,
    gridSize,
    "photoCount": count(*[_type == "photo" && references(^._id)]),
    "photos": *[_type == "photo" && references(^._id)] | order(_createdAt desc) {
      _id,
      title,
      "imageUrl": image.asset->url,
      "width": image.asset->metadata.dimensions.width,
      "height": image.asset->metadata.dimensions.height,
      camera,
      focalLength,
      aperture,
      shutterSpeed,
      iso,
      styleCategory,
      location
    }
  }
`);
---

<Layout>
  <HomePage client:load collections={collections} />
</Layout>
