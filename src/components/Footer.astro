---
// Shared site footer — used across all pages
interface Props {
  dark?: boolean;
}
const { dark = false } = Astro.props;
---
<footer class:list={[
  "py-20 px-6 md:px-16 max-w-7xl mx-auto border-t mt-12",
  dark ? "border-white/5" : "border-gray-100"
]}>
  <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
    <div>
      <h2 class:list={[
        "text-lg font-light tracking-tight",
        dark ? "text-white/80" : "text-gray-900"
      ]}>Visual Archive.</h2>
      <p class:list={[
        "text-xs mt-1 font-light",
        dark ? "text-white/30" : "text-gray-400"
      ]}>
        &copy; {new Date().getFullYear()} Ryan. All rights reserved.
      </p>
    </div>
    <div class:list={[
      "flex items-center gap-4 text-xs font-mono",
      dark ? "text-white/30" : "text-gray-400"
    ]}>
      <span>Fujifilm X-T50</span>
      <span class:list={[dark ? "text-white/10" : "text-gray-200"]}>&middot;</span>
      <span>Nikon Zf</span>
    </div>
  </div>
</footer>
